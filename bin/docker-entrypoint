#!/bin/bash -e

# Ensure the database schema exists and is current before the app starts.
# Idempotent and safe on every boot; baked into the image so it always runs
# no matter how Render passes the container command. Skipped only when the
# container is explicitly invoked to run a database task itself.
case "$*" in
  *db:prepare*|*db:migrate*|*db:setup*) ;;
  *) ./bin/rails db:prepare ;;
esac

exec "${@}"
