<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Invoice <%= @booking.invoice_reference %> — Crewbnb</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%= csrf_meta_tags %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: "Inter", -apple-system, sans-serif; color: #1e293b; background: #f1f5f9; padding: 32px 16px; }
      .sheet { max-width: 800px; margin: 0 auto; background: #fff; border-radius: 16px; box-shadow: 0 4px 24px rgba(0,0,0,0.08); padding: 48px; }
      .toolbar { max-width: 800px; margin: 0 auto 16px; display: flex; justify-content: flex-end; gap: 12px; }
      .btn { font: inherit; font-weight: 600; font-size: 14px; border: 0; border-radius: 10px; padding: 10px 18px; cursor: pointer; text-decoration: none; }
      .btn-primary { background: #0F224F; color: #fff; }
      .btn-ghost { background: #fff; color: #0F224F; border: 1px solid #cbd5e1; }
      @media print {
        body { background: #fff; padding: 0; }
        .sheet { box-shadow: none; border-radius: 0; padding: 0; max-width: none; }
        .no-print { display: none !important; }
      }
    </style>
  </head>
  <body>
    <div class="toolbar no-print">
      <a href="<%= booking_path(@booking) %>" class="btn btn-ghost">&larr; Back to booking</a>
      <button onclick="window.print()" class="btn btn-primary">Print / Save as PDF</button>
    </div>
    <div class="sheet">
      <%= yield %>
    </div>
  </body>
</html>
