<!DOCTYPE html>
<html class="scroll-smooth" lang="en">
  <head>
    <title><%= content_for(:title) || "Admin - Crewbnb" %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Crewbnb">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Google Fonts: Manrope, Inter, Material Symbols Outlined %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-background font-body text-on-background antialiased">
    <div class="flex min-h-screen" data-controller="sidebar">
      <%# Mobile Overlay %>
      <div data-sidebar-target="overlay" class="fixed inset-0 bg-black/40 z-30 hidden lg:hidden" data-action="click->sidebar#close"></div>

      <%# ===== Admin Sidebar ===== %>
      <aside data-sidebar-target="sidebar" class="fixed top-0 left-0 h-screen w-64 bg-tertiary text-on-tertiary flex flex-col z-40 -translate-x-full lg:translate-x-0 transition-transform duration-300">
        <%# Brand %>
        <div class="px-6 py-5 border-b border-tertiary-container/30">
          <%= link_to root_path, class: "text-xl font-extrabold tracking-tighter text-on-primary-container font-headline" do %>
            Crewbnb
          <% end %>
          <p class="text-xs text-on-tertiary-container font-label font-medium mt-1 uppercase tracking-widest">Administration</p>
        </div>

        <%# Navigation %>
        <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto">
          <%= link_to admin_root_path, class: "flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-colors duration-200 #{ current_page?(admin_root_path) ? 'bg-tertiary-container text-on-primary-container font-bold' : 'text-on-tertiary-container hover:bg-tertiary-container/40 hover:text-on-primary-container' }" do %>
            <span class="material-symbols-outlined text-xl">dashboard</span>
            <span class="text-sm">Dashboard</span>
          <% end %>

          <%= link_to admin_users_path, class: "flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-colors duration-200 #{ request.path.start_with?('/admin/users') ? 'bg-tertiary-container text-on-primary-container font-bold' : 'text-on-tertiary-container hover:bg-tertiary-container/40 hover:text-on-primary-container' }" do %>
            <span class="material-symbols-outlined text-xl">group</span>
            <span class="text-sm">Users</span>
          <% end %>

          <%= link_to admin_properties_path, class: "flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-colors duration-200 #{ request.path.start_with?('/admin/properties') ? 'bg-tertiary-container text-on-primary-container font-bold' : 'text-on-tertiary-container hover:bg-tertiary-container/40 hover:text-on-primary-container' }" do %>
            <span class="material-symbols-outlined text-xl">apartment</span>
            <span class="text-sm">Properties</span>
          <% end %>

          <%= link_to admin_bookings_path, class: "flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-colors duration-200 #{ request.path.start_with?('/admin/bookings') ? 'bg-tertiary-container text-on-primary-container font-bold' : 'text-on-tertiary-container hover:bg-tertiary-container/40 hover:text-on-primary-container' }" do %>
            <span class="material-symbols-outlined text-xl">calendar_month</span>
            <span class="text-sm">Bookings</span>
          <% end %>

          <%= link_to admin_reviews_path, class: "flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-colors duration-200 #{ request.path.start_with?('/admin/reviews') ? 'bg-tertiary-container text-on-primary-container font-bold' : 'text-on-tertiary-container hover:bg-tertiary-container/40 hover:text-on-primary-container' }" do %>
            <span class="material-symbols-outlined text-xl">reviews</span>
            <span class="text-sm">Reviews</span>
          <% end %>

          <%= link_to admin_contact_submissions_path, class: "flex items-center gap-3 px-4 py-3 rounded-xl font-medium transition-colors duration-200 #{ request.path.start_with?('/admin/contact_submissions') ? 'bg-tertiary-container text-on-primary-container font-bold' : 'text-on-tertiary-container hover:bg-tertiary-container/40 hover:text-on-primary-container' }" do %>
            <span class="material-symbols-outlined text-xl">mail</span>
            <span class="text-sm">Messages</span>
            <% unread = ContactSubmission.pending.count %>
            <% if unread > 0 %>
              <span class="ml-auto bg-error text-on-error text-[10px] font-bold px-1.5 py-0.5 rounded-full min-w-[18px] text-center"><%= unread %></span>
            <% end %>
          <% end %>
        </nav>

        <%# User Info / Back to Site %>
        <div class="px-4 py-4 border-t border-tertiary-container/30 space-y-2">
          <%= link_to root_path, class: "flex items-center gap-3 px-4 py-3 rounded-xl text-on-tertiary-container font-medium hover:bg-tertiary-container/40 hover:text-on-primary-container transition-colors duration-200" do %>
            <span class="material-symbols-outlined text-xl">arrow_back</span>
            <span class="text-sm">Back to Site</span>
          <% end %>

          <%= button_to destroy_user_session_path, method: :delete, class: "flex items-center gap-3 px-4 py-3 rounded-xl text-error-container font-medium hover:bg-error-container/10 transition-colors duration-200 w-full" do %>
            <span class="material-symbols-outlined text-xl">logout</span>
            <span class="text-sm">Sign Out</span>
          <% end %>
        </div>
      </aside>

      <%# ===== Main Content Area ===== %>
      <div class="flex-1 lg:ml-64">
        <%# Top Bar %>
        <header class="sticky top-0 z-30 bg-surface-container-lowest/80 backdrop-blur-xl border-b border-outline-variant/15">
          <div class="flex items-center justify-between px-8 py-4">
            <div class="flex items-center gap-3">
              <button data-action="click->sidebar#toggle" class="lg:hidden text-on-surface-variant p-1 cursor-pointer">
                <span class="material-symbols-outlined text-2xl">menu</span>
              </button>
              <h1 class="font-headline text-lg font-bold text-on-surface">
                <%= content_for?(:page_title) ? yield(:page_title) : "Admin Dashboard" %>
              </h1>
            </div>

            <div class="flex items-center gap-4">
              <%# User Avatar %>
              <div class="flex items-center gap-3">
                <span class="text-sm font-medium text-on-surface-variant"><%= current_user.email %></span>
                <% if current_user.avatar.attached? %>
                  <%= image_tag current_user.avatar, class: "w-8 h-8 rounded-full object-cover" %>
                <% else %>
                  <div class="w-8 h-8 rounded-full bg-primary-container flex items-center justify-center">
                    <span class="text-on-primary-container text-sm font-bold"><%= current_user.email[0].upcase %></span>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </header>

        <%# Flash Messages %>
        <% if notice.present? || alert.present? %>
          <div class="px-8 pt-4">
            <% if notice.present? %>
              <div class="flash-notice mb-3 flex items-center gap-3">
                <span class="material-symbols-outlined text-secondary">check_circle</span>
                <span class="flex-1 text-sm font-medium"><%= notice %></span>
              </div>
            <% end %>
            <% if alert.present? %>
              <div class="flash-alert mb-3 flex items-center gap-3">
                <span class="material-symbols-outlined text-error">error</span>
                <span class="flex-1 text-sm font-medium"><%= alert %></span>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# Page Content %>
        <main class="p-8">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
