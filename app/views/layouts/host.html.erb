<!DOCTYPE html>
<html class="scroll-smooth" lang="en">
  <head>
    <title><%= content_for(:title) || "Host Dashboard - Crewbnb" %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Crewbnb">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Google Fonts: Manrope, Inter, Material Symbols Outlined %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">

    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-white font-body text-ink antialiased min-h-screen">
    <%
      today_active    = request.path == host_root_path
      calendar_active = request.path.start_with?("/host/calendar")
      listings_active = request.path.start_with?("/host/properties")
      bookings_active = request.path.start_with?("/host/bookings")
      messages_active = request.path.start_with?("/host/conversations")
      tabs = [
        { label: "Today",    icon: "home",             path: host_root_path,            active: today_active },
        { label: "Calendar", icon: "calendar_month",   path: host_calendar_path,        active: calendar_active },
        { label: "Listings", icon: "apartment",        path: host_properties_path,      active: listings_active },
        { label: "Bookings", icon: "event_available",  path: host_bookings_path,        active: bookings_active },
        { label: "Messages", icon: "chat_bubble",      path: host_conversations_path,   active: messages_active }
      ]
    %>

    <%# ===== Top navigation ===== %>
    <header class="sticky top-0 z-40 bg-white border-b border-line">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
        <div class="h-16 flex items-center justify-between gap-4">
          <%# Brand %>
          <%= link_to host_root_path, class: "flex items-center flex-shrink-0", "aria-label": "crewbnb host home" do %>
            <%= image_tag "crewbnb-lockup-horizontal-navy.svg", alt: "crewbnb", class: "h-7 w-auto hidden sm:block" %>
            <%= image_tag "crewbnb-mark-navy.svg", alt: "crewbnb", class: "h-8 w-8 sm:hidden" %>
          <% end %>

          <%# Center tabs (desktop) %>
          <nav class="hidden lg:flex items-center gap-1">
            <% tabs.each do |t| %>
              <%= link_to t[:path], class: "abb-tab #{'active' if t[:active]}" do %>
                <span class="material-symbols-outlined text-lg"><%= t[:icon] %></span>
                <%= t[:label] %>
              <% end %>
            <% end %>
          </nav>

          <%# Right actions %>
          <div class="flex items-center gap-2 flex-shrink-0">
            <%= link_to new_host_property_path, class: "abb-btn hidden sm:inline-flex" do %>
              <span class="material-symbols-outlined text-lg">add</span>
              <span class="hidden md:inline">New listing</span>
            <% end %>

            <%# Account menu (pure-CSS dropdown) %>
            <details class="relative [&_summary::-webkit-details-marker]:hidden">
              <summary class="list-none cursor-pointer flex items-center gap-2 border border-line rounded-full pl-3 pr-1.5 py-1.5 hover:shadow-md transition-shadow">
                <span class="material-symbols-outlined text-lg text-ink">menu</span>
                <% if current_user.avatar.attached? %>
                  <%= image_tag current_user.avatar, class: "w-7 h-7 rounded-full object-cover" %>
                <% else %>
                  <span class="w-7 h-7 rounded-full bg-brand flex items-center justify-center text-white text-xs font-bold"><%= current_user.email[0].upcase %></span>
                <% end %>
              </summary>
              <div class="absolute right-0 mt-2 w-60 bg-white rounded-2xl border border-line shadow-[0_6px_20px_rgba(0,0,0,0.12)] py-2 z-50">
                <div class="px-4 py-2 border-b border-line mb-1">
                  <p class="text-sm font-bold text-ink truncate"><%= current_user.first_name.presence || "Host" %></p>
                  <p class="text-xs text-muted truncate"><%= current_user.email %></p>
                </div>
                <%= link_to new_host_property_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm font-semibold text-ink hover:bg-neutral-50 sm:hidden" do %>
                  <span class="material-symbols-outlined text-lg text-muted">add</span> New listing
                <% end %>
                <%= link_to edit_user_registration_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-ink hover:bg-neutral-50" do %>
                  <span class="material-symbols-outlined text-lg text-muted">settings</span> Account &amp; password
                <% end %>
                <%= link_to root_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-ink hover:bg-neutral-50" do %>
                  <span class="material-symbols-outlined text-lg text-muted">public</span> Switch to guest site
                <% end %>
                <% if current_user.admin? %>
                  <%= link_to admin_root_path, class: "flex items-center gap-3 px-4 py-2.5 text-sm text-ink hover:bg-neutral-50" do %>
                    <span class="material-symbols-outlined text-lg text-muted">shield_person</span> Admin
                  <% end %>
                <% end %>
                <div class="border-t border-line mt-1 pt-1">
                  <%= button_to destroy_user_session_path, method: :delete, class: "w-full flex items-center gap-3 px-4 py-2.5 text-sm text-ink hover:bg-neutral-50" do %>
                    <span class="material-symbols-outlined text-lg text-muted">logout</span> Sign out
                  <% end %>
                </div>
              </div>
            </details>
          </div>
        </div>

        <%# Tabs (mobile) — horizontally scrollable %>
        <nav class="lg:hidden flex items-center gap-1 overflow-x-auto no-scrollbar pb-2 -mt-1">
          <% tabs.each do |t| %>
            <%= link_to t[:path], class: "abb-tab #{'active' if t[:active]}" do %>
              <span class="material-symbols-outlined text-lg"><%= t[:icon] %></span>
              <%= t[:label] %>
            <% end %>
          <% end %>
        </nav>
      </div>
    </header>

    <%# ===== Flash messages ===== %>
    <% if notice.present? || alert.present? %>
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 pt-4">
        <% if notice.present? %>
          <div class="flex items-center gap-3 bg-green-50 text-green-800 border border-green-200 px-4 py-3 rounded-xl mb-2">
            <span class="material-symbols-outlined">check_circle</span>
            <span class="flex-1 text-sm font-medium"><%= notice %></span>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="flex items-center gap-3 bg-brand/10 text-brand-dark border border-brand/25 px-4 py-3 rounded-xl mb-2">
            <span class="material-symbols-outlined">error</span>
            <span class="flex-1 text-sm font-medium"><%= alert %></span>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ===== Page content ===== %>
    <main class="max-w-screen-xl mx-auto px-4 sm:px-6 py-8">
      <%= yield %>
    </main>
  </body>
</html>
