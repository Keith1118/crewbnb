<% content_for(:title, "Our properties — Crewbnb") %>
<% meta_description "Our crew accommodation listings. Weekday pricing, parking, fast WiFi, and proper invoices." %>

<section class="bg-surface-container-low border-b border-outline-variant/20">
  <div class="max-w-screen-xl mx-auto px-6 md:px-8 py-10">
    <h1 class="font-headline text-3xl md:text-4xl font-extrabold text-on-surface tracking-tight">
      Our properties
    </h1>
  </div>
</section>

<%# Results Section %>
<section class="max-w-screen-xl mx-auto px-6 md:px-8 py-8">
  <% if @properties.any? %>
    <%# Property Grid %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <%= render partial: "property_card", collection: @properties, as: :property %>
    </div>
  <% else %>
    <%# Empty State %>
    <div class="text-center py-20">
      <span class="material-symbols-outlined text-6xl text-outline-variant/40 mb-4">search_off</span>
      <h2 class="font-headline text-xl font-bold text-on-surface mt-4">No properties listed yet</h2>
      <p class="text-on-surface-variant mt-2 max-w-md mx-auto">
        Check back soon.
      </p>
    </div>
  <% end %>
</section>
