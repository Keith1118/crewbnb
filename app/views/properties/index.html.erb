<% content_for(:title, "Rooms & crew accommodation — Crewbnb") %>
<% meta_description "Browse crew accommodation with weekday pricing, free parking, fast Wi-Fi, and proper invoices. Search by dates and team size." %>

<section class="bg-surface-container-low border-b border-outline-variant/20">
  <div class="max-w-screen-xl mx-auto px-6 md:px-8 py-10">
    <h1 class="font-headline text-3xl md:text-4xl font-extrabold text-on-surface tracking-tight mb-6">
      Our properties
    </h1>

    <%# Search & Filters %>
    <%= form_with url: properties_path, method: :get, class: "grid grid-cols-2 md:grid-cols-12 gap-3 items-end" do |f| %>
      <div class="col-span-2 md:col-span-4">
        <%= label_tag :near, "Where's the job?", class: "block text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-1" %>
        <%= text_field_tag :near, params[:near], placeholder: "Town or county in Ireland",
            class: "w-full px-4 py-3 rounded-xl bg-surface-container-lowest border border-outline-variant/30 text-on-surface text-sm focus:outline-none focus:ring-2 focus:ring-primary-container" %>
      </div>
      <div class="md:col-span-2">
        <%= label_tag :check_in, "Check-in", class: "block text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-1" %>
        <%= date_field_tag :check_in, params[:check_in], min: Date.current,
            class: "w-full px-3 py-3 rounded-xl bg-surface-container-lowest border border-outline-variant/30 text-on-surface text-sm focus:outline-none focus:ring-2 focus:ring-primary-container" %>
      </div>
      <div class="md:col-span-2">
        <%= label_tag :check_out, "Check-out", class: "block text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-1" %>
        <%= date_field_tag :check_out, params[:check_out], min: Date.current + 1,
            class: "w-full px-3 py-3 rounded-xl bg-surface-container-lowest border border-outline-variant/30 text-on-surface text-sm focus:outline-none focus:ring-2 focus:ring-primary-container" %>
      </div>
      <div class="md:col-span-2">
        <%= label_tag :guests, "Beds", class: "block text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-1" %>
        <%= number_field_tag :guests, params[:guests], min: 1, placeholder: "1",
            class: "w-full px-3 py-3 rounded-xl bg-surface-container-lowest border border-outline-variant/30 text-on-surface text-sm focus:outline-none focus:ring-2 focus:ring-primary-container" %>
      </div>
      <div class="md:col-span-2">
        <%= submit_tag "Search", data: { turbo_submits_with: "Searching…" }, class: "w-full bg-primary-container text-on-primary-container px-6 py-3 rounded-xl font-headline font-bold text-sm hover:bg-primary transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</section>

<%# Results Section %>
<section class="max-w-screen-xl mx-auto px-6 md:px-8 py-8">
  <%# Results bar: count + sort %>
  <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
    <p class="text-sm text-on-surface-variant">
      <span class="font-semibold text-on-surface"><%= @pagy.count %></span>
      <%= @pagy.count == 1 ? "stay" : "stays" %>
      <% if params[:check_in].present? && params[:check_out].present? %>
        available for your dates
      <% end %>
      <% if @near.present? && @origin.present? %>
        &middot; nearest to <span class="font-medium text-on-surface"><%= @near %></span> first
      <% elsif @near.present? %>
        &middot; <span class="text-amber-600">couldn't find "<%= @near %>" — showing all stays</span>
      <% end %>
    </p>

    <%= form_with url: properties_path, method: :get, class: "flex items-center gap-2" do %>
      <% [:query, :near, :check_in, :check_out, :guests].each do |key| %>
        <%= hidden_field_tag key, params[key] if params[key].present? %>
      <% end %>
      <%= label_tag :sort, "Sort by", class: "text-sm text-on-surface-variant" %>
      <%= select_tag :sort,
          options_for_select([["Newest", "newest"], ["Price: low to high", "price_asc"], ["Price: high to low", "price_desc"]], params[:sort]),
          onchange: "this.form.requestSubmit()",
          class: "px-3 py-2 rounded-xl bg-surface-container-lowest border border-outline-variant/30 text-on-surface text-sm focus:outline-none focus:ring-2 focus:ring-primary-container" %>
    <% end %>
  </div>

  <% if @properties.any? %>
    <%# Property Grid %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <%= render partial: "property_card", collection: @properties, as: :property %>
    </div>

    <% if @pagy.pages > 1 %>
      <nav class="mt-10 flex justify-center" aria-label="Pagination">
        <%== pagy_nav(@pagy) %>
      </nav>
    <% end %>
  <% else %>
    <%# Empty State %>
    <div class="text-center py-20">
      <span class="material-symbols-outlined text-6xl text-outline-variant/40 mb-4" aria-hidden="true">search_off</span>
      <% if params.values_at(:query, :near, :check_in, :check_out, :guests).any?(&:present?) %>
        <h2 class="font-headline text-xl font-bold text-on-surface mt-4">No stays match your search</h2>
        <p class="text-on-surface-variant mt-2 max-w-md mx-auto">
          Try different dates, fewer guests, or a broader search term.
        </p>
        <%= link_to "Clear search", properties_path, class: "inline-block mt-6 bg-primary-container text-on-primary-container px-6 py-3 rounded-xl font-semibold text-sm hover:bg-primary transition-colors" %>
      <% else %>
        <h2 class="font-headline text-xl font-bold text-on-surface mt-4">No properties listed yet</h2>
        <p class="text-on-surface-variant mt-2 max-w-md mx-auto">
          Check back soon.
        </p>
      <% end %>
    </div>
  <% end %>
</section>
