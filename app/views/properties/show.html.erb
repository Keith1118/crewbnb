<% content_for(:title, "#{@property.title} - Crewbase") %>
<% meta_description "#{@property.title} in #{@property.city}, #{@property.country}. #{@property.bedrooms} beds, #{@property.max_guests} guests. From EUR #{@property.price_per_night.to_i}/night. Book on Crewbase." %>

<% content_for(:head) do %>
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LodgingBusiness",
      "name": <%= @property.title.to_json %>,
      "description": <%= @property.description.to_s.truncate(300).to_json %>,
      "url": <%= property_url(@property).to_json %>,
      <% if @property.images.attached? %>
      "image": <%= url_for(@property.images.first).to_json %>,
      <% end %>
      "address": {
        "@type": "PostalAddress",
        <% if @property.address.present? %>
        "streetAddress": <%= @property.address.to_json %>,
        <% end %>
        "addressLocality": <%= @property.city.to_json %>,
        "addressCountry": <%= @property.country.to_json %>
      },
      <% if @property.latitude.present? && @property.longitude.present? %>
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": <%= @property.latitude %>,
        "longitude": <%= @property.longitude %>
      },
      <% end %>
      <% if @property.average_rating && @property.reviews.any? %>
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": <%= @property.average_rating %>,
        "reviewCount": <%= @property.reviews.count %>
      },
      <% end %>
      "checkinTime": <%= (@property.check_in_time.presence || "3:00 PM").to_json %>,
      "checkoutTime": <%= (@property.check_out_time.presence || "10:30 AM").to_json %>,
      "priceRange": "€<%= @property.price_per_night.to_i %> per night"
    }
  </script>
<% end %>

<%# Deterministic gradient for placeholders %>
<% hue_1 = (@property.id * 37) % 360 %>
<% hue_2 = (hue_1 + 40) % 360 %>
<% hue_3 = (hue_1 + 80) % 360 %>

<div class="max-w-screen-xl mx-auto px-6 md:px-8 py-8">
  <%# Breadcrumb %>
  <nav class="flex items-center gap-2 text-sm text-on-surface-variant mb-6">
    <%= link_to "Properties", properties_path, class: "hover:text-primary-container transition-colors" %>
    <span class="material-symbols-outlined text-base">chevron_right</span>
    <span class="text-on-surface font-medium truncate"><%= @property.title %></span>
  </nav>

  <%# Property Header %>
  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-6">
    <div>
      <h1 class="font-headline text-2xl md:text-3xl font-extrabold text-on-surface tracking-tight">
        <%= @property.title %>
      </h1>
      <div class="flex items-center gap-2 mt-2">
        <span class="material-symbols-outlined text-on-surface-variant text-lg">location_on</span>
        <p class="text-on-surface-variant font-medium"><%= [@property.city, @property.country].compact.join(", ") %></p>
      </div>
      <div class="flex items-center gap-2 mt-2">
        <span class="material-symbols-outlined text-on-surface-variant text-lg">person</span>
        <p class="text-on-surface-variant">
          Hosted by <span class="font-semibold text-on-surface"><%= @property.user.first_name || @property.user.email.split("@").first %></span>
        </p>
        <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-lg text-xs font-semibold bg-primary-container/10 text-primary-container">
          <span class="material-symbols-outlined text-sm" aria-hidden="true">verified</span>
          Verified host
        </span>
      </div>
    </div>

    <%# Favorite Button (header) %>
    <div class="flex items-center gap-3">
      <% if user_signed_in? %>
        <% if @is_favorited %>
          <%= button_to unfavorite_property_path(@property), method: :delete, class: "inline-flex items-center gap-2 px-4 py-2.5 rounded-xl border border-error/30 text-error hover:bg-error-container/20 transition-colors text-sm font-bold cursor-pointer" do %>
            <span class="material-symbols-outlined text-lg" style="font-variation-settings: 'FILL' 1;">favorite</span>
            Saved
          <% end %>
        <% else %>
          <%= button_to favorite_property_path(@property), method: :post, class: "inline-flex items-center gap-2 px-4 py-2.5 rounded-xl border border-outline-variant/30 text-on-surface-variant hover:bg-surface-container transition-colors text-sm font-bold cursor-pointer" do %>
            <span class="material-symbols-outlined text-lg">favorite</span>
            Save
          <% end %>
        <% end %>
      <% else %>
        <%= link_to new_user_session_path, class: "inline-flex items-center gap-2 px-4 py-2.5 rounded-xl border border-outline-variant/30 text-on-surface-variant hover:bg-surface-container transition-colors text-sm font-bold" do %>
          <span class="material-symbols-outlined text-lg">favorite</span>
          Save
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Image Gallery — swipeable on mobile, grid on desktop %>
  <div class="flex overflow-x-auto snap-x snap-mandatory no-scrollbar gap-3 md:grid md:grid-cols-4 md:overflow-hidden rounded-2xl mb-10">
    <% if @property.images.attached? %>
      <%# Main Image %>
      <div class="flex-shrink-0 w-[88%] snap-center md:w-auto md:flex-shrink md:col-span-2 md:row-span-2 aspect-[4/3] md:aspect-auto rounded-2xl md:rounded-none overflow-hidden">
        <%= image_tag sized_image(@property.images.first, resize_to_limit: [1600, 1200]), class: "w-full h-full object-cover", alt: "#{@property.title} — main photo" %>
      </div>
      <%# Secondary Images %>
      <% @property.images.drop(1).first(4).each_with_index do |image, index| %>
        <div class="flex-shrink-0 w-[88%] snap-center md:w-auto md:flex-shrink aspect-[4/3] rounded-2xl md:rounded-none overflow-hidden">
          <%= image_tag sized_image(image, resize_to_fill: [800, 600]), class: "w-full h-full object-cover", loading: "lazy", alt: "#{@property.title} — photo #{index + 2}" %>
        </div>
      <% end %>
      <%# Fill remaining slots with gradient placeholders %>
      <% remaining = 4 - [@property.images.drop(1).size, 4].min %>
      <% remaining.times do |i| %>
        <div class="hidden md:block aspect-[4/3]"
             style="background: linear-gradient(135deg, hsl(<%= (hue_1 + i * 30) % 360 %>, 40%, 40%) 0%, hsl(<%= (hue_2 + i * 30) % 360 %>, 50%, 30%) 100%);">
        </div>
      <% end %>
    <% else %>
      <%# All gradient placeholders %>
      <div class="md:col-span-2 md:row-span-2 aspect-[4/3] md:aspect-auto"
           style="background: linear-gradient(135deg, hsl(<%= hue_1 %>, 45%, 35%) 0%, hsl(<%= hue_2 %>, 55%, 25%) 100%);">
        <div class="flex items-center justify-center h-full">
          <span class="material-symbols-outlined text-white/30 text-6xl">image</span>
        </div>
      </div>
      <% 4.times do |i| %>
        <div class="hidden md:block aspect-[4/3]"
             style="background: linear-gradient(135deg, hsl(<%= (hue_1 + (i + 1) * 25) % 360 %>, 40%, 40%) 0%, hsl(<%= (hue_3 + i * 25) % 360 %>, 50%, 30%) 100%);">
        </div>
      <% end %>
    <% end %>
  </div>

  <%# Property Specs Bar %>
  <div class="flex flex-wrap items-center gap-6 bg-surface-container rounded-2xl p-5 mb-10">
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-primary-container text-xl">apartment</span>
      <span class="text-sm font-medium text-on-surface"><%= @property.property_type || "Property" %></span>
    </div>
    <div class="w-px h-5 bg-outline-variant/30 hidden sm:block"></div>
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-primary-container text-xl">bed</span>
      <span class="text-sm font-medium text-on-surface"><%= @property.bedrooms %> Bedroom<%= @property.bedrooms == 1 ? "" : "s" %></span>
    </div>
    <div class="w-px h-5 bg-outline-variant/30 hidden sm:block"></div>
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-primary-container text-xl">single_bed</span>
      <span class="text-sm font-medium text-on-surface"><%= @property.max_guests %> Bed<%= @property.max_guests == 1 ? "" : "s" %></span>
    </div>
    <div class="w-px h-5 bg-outline-variant/30 hidden sm:block"></div>
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-primary-container text-xl">bathroom</span>
      <span class="text-sm font-medium text-on-surface"><%= @property.bathrooms %> Bathroom<%= @property.bathrooms == 1 ? "" : "s" %></span>
    </div>
    <div class="w-px h-5 bg-outline-variant/30 hidden sm:block"></div>
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-primary-container text-xl">group</span>
      <span class="text-sm font-medium text-on-surface">Up to <%= @property.max_guests %> Guest<%= @property.max_guests == 1 ? "" : "s" %></span>
    </div>
    <% if @property.average_rating %>
      <div class="w-px h-5 bg-outline-variant/30 hidden sm:block"></div>
      <div class="flex items-center gap-1">
        <span class="material-symbols-outlined text-amber-500 text-xl" style="font-variation-settings: 'FILL' 1;">star</span>
        <span class="text-sm font-bold text-on-surface"><%= @property.average_rating %></span>
        <span class="text-sm text-on-surface-variant">(<%= @property.reviews.count %> review<%= @property.reviews.count == 1 ? "" : "s" %>)</span>
      </div>
    <% end %>
  </div>

  <%# Main Content: Details + Booking Card %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
    <%# Left Column: Description, Amenities, Work Features %>
    <div class="lg:col-span-2 space-y-10">
      <%# Description %>
      <section>
        <h2 class="font-headline text-xl font-bold text-on-surface mb-4">About this property</h2>
        <div class="text-on-surface-variant leading-relaxed whitespace-pre-line"><%= @property.description %></div>
      </section>

      <%# Work Features %>
      <section>
        <h2 class="font-headline text-xl font-bold text-on-surface mb-4">
          <span class="material-symbols-outlined text-primary-container align-middle mr-1">work</span>
          Work Features
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="flex items-center gap-3 p-4 rounded-xl bg-surface-container border border-outline-variant/10">
            <span class="material-symbols-outlined text-xl <%= @property.has_desk? ? 'text-primary-container' : 'text-outline-variant' %>">desk</span>
            <div>
              <p class="text-sm font-semibold text-on-surface">Dedicated Desk</p>
              <p class="text-xs text-on-surface-variant"><%= @property.has_desk? ? "Available" : "Not available" %></p>
            </div>
          </div>
          <div class="flex items-center gap-3 p-4 rounded-xl bg-surface-container border border-outline-variant/10">
            <span class="material-symbols-outlined text-xl <%= @property.has_meeting_room? ? 'text-primary-container' : 'text-outline-variant' %>">meeting_room</span>
            <div>
              <p class="text-sm font-semibold text-on-surface">Meeting Room</p>
              <p class="text-xs text-on-surface-variant"><%= @property.has_meeting_room? ? "Available" : "Not available" %></p>
            </div>
          </div>
          <div class="flex items-center gap-3 p-4 rounded-xl bg-surface-container border border-outline-variant/10">
            <span class="material-symbols-outlined text-xl <%= @property.has_printer? ? 'text-primary-container' : 'text-outline-variant' %>">print</span>
            <div>
              <p class="text-sm font-semibold text-on-surface">Printer</p>
              <p class="text-xs text-on-surface-variant"><%= @property.has_printer? ? "Available" : "Not available" %></p>
            </div>
          </div>
          <div class="flex items-center gap-3 p-4 rounded-xl bg-surface-container border border-outline-variant/10">
            <span class="material-symbols-outlined text-xl <%= @property.wifi_speed.present? ? 'text-primary-container' : 'text-outline-variant' %>">wifi</span>
            <div>
              <p class="text-sm font-semibold text-on-surface">Wi-Fi</p>
              <p class="text-xs text-on-surface-variant"><%= @property.wifi_speed.present? ? @property.wifi_speed : "Not specified" %></p>
            </div>
          </div>
          <div class="flex items-center gap-3 p-4 rounded-xl bg-surface-container border border-outline-variant/10">
            <span class="material-symbols-outlined text-xl <%= @property.has_parking? ? 'text-primary-container' : 'text-outline-variant' %>">local_parking</span>
            <div>
              <p class="text-sm font-semibold text-on-surface">Parking</p>
              <p class="text-xs text-on-surface-variant"><%= @property.has_parking? ? "Available" : "Not available" %></p>
            </div>
          </div>
        </div>
      </section>

      <%# Amenities %>
      <% if @property.amenities.any? %>
        <section>
          <h2 class="font-headline text-xl font-bold text-on-surface mb-4">Amenities</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
            <% @property.amenities.each do |amenity| %>
              <div class="flex items-center gap-3 p-3 rounded-xl bg-surface-container-low border border-outline-variant/10">
                <span class="material-symbols-outlined text-primary-container text-xl" aria-hidden="true"><%= amenity.icon.present? ? amenity.icon : "check_circle" %></span>
                <span class="text-sm font-medium text-on-surface"><%= amenity.name %></span>
              </div>
            <% end %>
          </div>
        </section>
      <% end %>

      <%# Sleeping Arrangements %>
      <% if @property.bed_configuration.present? %>
        <section>
          <h2 class="font-headline text-xl font-bold text-on-surface mb-4">Sleeping arrangements</h2>
          <div class="flex items-center gap-3 p-4 rounded-xl bg-surface-container border border-outline-variant/10 max-w-md">
            <span class="material-symbols-outlined text-primary-container text-xl" aria-hidden="true">king_bed</span>
            <span class="text-sm font-medium text-on-surface"><%= @property.bed_configuration %></span>
          </div>
        </section>
      <% end %>

      <%# House Rules & Check-in %>
      <section>
        <h2 class="font-headline text-xl font-bold text-on-surface mb-4">Good to know</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
          <div class="flex items-center gap-3 p-4 rounded-xl bg-surface-container border border-outline-variant/10">
            <span class="material-symbols-outlined text-primary-container text-xl" aria-hidden="true">login</span>
            <div>
              <p class="text-sm font-semibold text-on-surface">Check-in</p>
              <p class="text-xs text-on-surface-variant">From <%= @property.check_in_time.presence || "3:00 PM" %></p>
            </div>
          </div>
          <div class="flex items-center gap-3 p-4 rounded-xl bg-surface-container border border-outline-variant/10">
            <span class="material-symbols-outlined text-primary-container text-xl" aria-hidden="true">logout</span>
            <div>
              <p class="text-sm font-semibold text-on-surface">Check-out</p>
              <p class="text-xs text-on-surface-variant">By <%= @property.check_out_time.presence || "10:30 AM" %></p>
            </div>
          </div>
        </div>
        <% if @property.house_rules.present? %>
          <div class="rounded-xl bg-surface-container-low border border-outline-variant/10 p-5">
            <h3 class="text-sm font-bold text-on-surface mb-2">House rules</h3>
            <div class="text-sm text-on-surface-variant leading-relaxed whitespace-pre-line"><%= @property.house_rules %></div>
          </div>
        <% end %>
      </section>

      <%# Nearby towns %>
      <% if @property.nearby_attractions.present? %>
        <section>
          <h2 class="font-headline text-xl font-bold text-on-surface mb-1 flex items-center gap-2">
            <span class="material-symbols-outlined text-primary-container" aria-hidden="true">near_me</span>
            Nearby towns
          </h2>
          <p class="text-xs text-on-surface-variant mb-4">Approximate drive times — handy for judging the commute to your job.</p>
          <div class="text-on-surface-variant text-sm leading-relaxed whitespace-pre-line"><%= @property.nearby_attractions %></div>
        </section>
      <% end %>
    </div>

    <%# Right Column: Booking Card %>
    <div class="lg:col-span-1">
      <div id="booking-card" class="sticky top-24 scroll-mt-24 bg-surface-container-lowest rounded-2xl border border-outline-variant/20 shadow-lg p-6 space-y-5"
           data-controller="booking-calc"
           data-booking-calc-price-value="<%= @property.price_per_night.to_f %>">
        <%# Price Display %>
        <div class="flex items-baseline gap-1">
          <span class="font-headline text-2xl font-extrabold text-on-surface"><%= number_to_currency(@property.price_per_night, precision: 0) %></span>
          <span class="text-on-surface-variant text-sm font-medium">/ night</span>
          <span class="text-on-surface-variant text-sm ml-auto"><%= number_to_currency(@property.weekly_price, precision: 0) %> / week</span>
        </div>

        <%# Booking Form %>
        <% instant = @property.instant_book? && StripeConfig.configured? %>
        <%= form_with model: @booking, url: property_bookings_path(@property), class: "space-y-4" do |f| %>
          <%# Check-in / Check-out %>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <%= f.label :check_in, "Check-in", class: "block text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-1" %>
              <%= f.date_field :check_in,
                  value: params[:check_in],
                  min: Date.current,
                  data: { booking_calc_target: "checkIn", action: "change->booking-calc#recalculate" },
                  class: "w-full px-3 py-3 rounded-xl bg-surface-container border border-outline-variant/30 text-on-surface text-sm focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-primary-container transition-colors" %>
            </div>
            <div>
              <%= f.label :check_out, "Check-out", class: "block text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-1" %>
              <%= f.date_field :check_out,
                  value: params[:check_out],
                  min: Date.current + 1,
                  data: { booking_calc_target: "checkOut", action: "change->booking-calc#recalculate" },
                  class: "w-full px-3 py-3 rounded-xl bg-surface-container border border-outline-variant/30 text-on-surface text-sm focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-primary-container transition-colors" %>
            </div>
          </div>

          <%# Guests %>
          <div>
            <%= f.label :guests_count, "Guests", class: "block text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-1" %>
            <%= f.number_field :guests_count, min: 1, max: @property.max_guests,
                value: params[:guests] || 1,
                class: "w-full px-3 py-3 rounded-xl bg-surface-container border border-outline-variant/30 text-on-surface text-sm focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-primary-container transition-colors" %>
            <p class="text-xs text-on-surface-variant mt-1">Sleeps up to <%= @property.max_guests %></p>
          </div>

          <%# Price Calculation Area %>
          <div class="border-t border-outline-variant/15 pt-4 space-y-2" aria-live="polite">
            <p class="text-sm text-on-surface-variant hidden" data-booking-calc-target="empty">Select dates to see your total.</p>
            <div data-booking-calc-target="breakdown">
              <div class="flex justify-between text-sm">
                <span class="text-on-surface-variant"><%= number_to_currency(@property.price_per_night, precision: 0) %> &times; <span data-booking-calc-target="nights">--</span> nights</span>
                <span class="text-on-surface font-medium" data-booking-calc-target="subtotal">--</span>
              </div>
              <div class="flex justify-between text-base font-bold pt-2 mt-2 border-t border-outline-variant/15">
                <span class="text-on-surface">Total</span>
                <span class="text-on-surface font-headline" data-booking-calc-target="total">--</span>
              </div>
              <p class="text-xs text-on-surface-variant mt-1">No service fees. The price you see is the price you pay.</p>
            </div>
          </div>

          <%# Submit — only promise instant booking when we can actually take payment %>
          <% if bookings_open? %>
            <%= f.submit instant ? "Book Now" : "Request to Book",
                data: { turbo_submits_with: "Sending…" },
                class: "w-full bg-primary-container text-on-primary-container py-3.5 rounded-xl font-headline font-bold text-sm hover:bg-primary transition-colors active:scale-[0.98] cursor-pointer" %>
            <% unless instant %>
              <p class="text-xs text-on-surface-variant text-center">You won't be charged yet</p>
            <% end %>
          <% else %>
            <%# Pre-launch: bookings not open yet %>
            <div class="w-full bg-surface-container text-on-surface-variant py-3.5 rounded-xl font-headline font-bold text-sm text-center opacity-70 cursor-not-allowed" aria-disabled="true">Bookings opening soon</div>
            <p class="text-xs text-on-surface-variant text-center">We're launching bookings shortly — check back soon.</p>
          <% end %>
        <% end %>

        <%# Trust signals %>
        <div class="space-y-2 pt-1">
          <% if instant %>
            <div class="flex items-center gap-2 text-xs text-on-surface-variant">
              <span class="material-symbols-outlined text-primary-container text-base" aria-hidden="true">bolt</span>
              <span>Instant booking &mdash; no approval needed</span>
            </div>
            <div class="flex items-center gap-2 text-xs text-on-surface-variant">
              <span class="material-symbols-outlined text-primary-container text-base" aria-hidden="true">lock</span>
              <span>Secure card payment via Stripe</span>
            </div>
          <% else %>
            <div class="flex items-center gap-2 text-xs text-on-surface-variant">
              <span class="material-symbols-outlined text-primary-container text-base" aria-hidden="true">schedule</span>
              <span>Host confirms quickly &mdash; usually the same day</span>
            </div>
            <div class="flex items-center gap-2 text-xs text-on-surface-variant">
              <span class="material-symbols-outlined text-primary-container text-base" aria-hidden="true">event_available</span>
              <span>Free to request &mdash; cancel anytime before confirmation</span>
            </div>
          <% end %>
          <div class="flex items-center gap-2 text-xs text-on-surface-variant">
            <span class="material-symbols-outlined text-primary-container text-base" aria-hidden="true">receipt_long</span>
            <span>VAT invoice with every booking</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Location — free Google Maps embed (no API key required) %>
  <% if @property.latitude.present? && @property.longitude.present? %>
    <% map_query = "#{@property.latitude},#{@property.longitude}" %>
  <% elsif [@property.address, @property.city, @property.country].any?(&:present?) %>
    <% map_query = [@property.address, @property.city, @property.country].compact_blank.join(", ") %>
  <% end %>
  <% if defined?(map_query) && map_query.present? %>
    <section class="mt-16 border-t border-outline-variant/20 pt-10">
      <div class="flex items-center gap-3 mb-6">
        <span class="material-symbols-outlined text-primary-container text-2xl">map</span>
        <h2 class="font-headline text-xl font-bold text-on-surface">Location</h2>
      </div>
      <div class="relative rounded-2xl overflow-hidden border border-outline-variant/15">
        <iframe
          title="Map showing <%= @property.title %>"
          src="https://maps.google.com/maps?q=<%= u map_query %>&z=14&output=embed"
          width="100%" height="420" style="border:0;"
          loading="lazy" referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen></iframe>
        <%= link_to "https://www.google.com/maps/search/?api=1&query=#{u map_query}", target: "_blank", rel: "noopener",
            class: "absolute top-3 left-3 z-10 inline-flex items-center gap-1.5 bg-white text-slate-800 text-xs font-semibold px-3 py-2 rounded-xl shadow-md hover:shadow-lg transition-shadow" do %>
          <span class="material-symbols-outlined text-base" aria-hidden="true">open_in_new</span>
          Open in Google Maps
        <% end %>
      </div>
    </section>
  <% end %>

  <%# Reviews Section %>
  <section class="mt-16 border-t border-outline-variant/20 pt-10">
    <div class="flex items-center gap-3 mb-8">
      <h2 class="font-headline text-xl font-bold text-on-surface">Reviews</h2>
      <% if @property.average_rating %>
        <div class="flex items-center gap-1 bg-surface-container px-3 py-1.5 rounded-xl">
          <span class="material-symbols-outlined text-amber-500 text-lg" style="font-variation-settings: 'FILL' 1;">star</span>
          <span class="text-sm font-bold text-on-surface"><%= @property.average_rating %></span>
          <span class="text-sm text-on-surface-variant">(<%= @reviews.count %>)</span>
        </div>
      <% end %>
    </div>

    <% if @reviews.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <% @reviews.each do |review| %>
          <div class="bg-surface-container-low rounded-2xl p-5 border border-outline-variant/10">
            <%# Reviewer Info %>
            <div class="flex items-center gap-3 mb-3">
              <% if review.reviewer.avatar.attached? %>
                <%= image_tag review.reviewer.avatar, class: "w-10 h-10 rounded-full object-cover" %>
              <% else %>
                <div class="w-10 h-10 rounded-full bg-primary-container/20 flex items-center justify-center">
                  <span class="text-primary-container text-sm font-bold"><%= review.reviewer.first_name&.first&.upcase || review.reviewer.email[0].upcase %></span>
                </div>
              <% end %>
              <div>
                <p class="text-sm font-semibold text-on-surface"><%= review.reviewer.first_name || review.reviewer.email.split("@").first %></p>
                <p class="text-xs text-on-surface-variant"><%= review.created_at.strftime("%B %Y") %></p>
              </div>
            </div>

            <%# Star Rating %>
            <div class="flex items-center gap-0.5 mb-3">
              <% review.rating.times do %>
                <span class="material-symbols-outlined text-amber-500 text-base" style="font-variation-settings: 'FILL' 1;">star</span>
              <% end %>
              <% (5 - review.rating).times do %>
                <span class="material-symbols-outlined text-outline-variant text-base">star</span>
              <% end %>
            </div>

            <%# Comment %>
            <p class="text-sm text-on-surface-variant leading-relaxed"><%= review.comment %></p>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12 bg-surface-container-low rounded-2xl">
        <span class="material-symbols-outlined text-4xl text-outline-variant/40">rate_review</span>
        <p class="text-on-surface-variant mt-3">No reviews yet. Be the first to stay and review!</p>
      </div>
    <% end %>
  </section>
</div>

<%# ===== Mobile sticky booking bar (hidden on desktop where the card is visible) ===== %>
<div class="lg:hidden sticky bottom-0 inset-x-0 z-40 bg-white/95 backdrop-blur border-t border-slate-200 px-4 py-3 pb-[calc(0.75rem+env(safe-area-inset-bottom))]">
  <div class="flex items-center justify-between gap-4">
    <div>
      <p class="font-headline text-lg font-extrabold text-on-surface leading-tight"><%= number_to_currency(@property.price_per_night, precision: 0) %><span class="text-sm font-medium text-on-surface-variant"> / night</span></p>
      <p class="text-xs text-on-surface-variant"><%= number_to_currency(@property.weekly_price, precision: 0) %> / week &middot; no fees</p>
    </div>
    <a href="#booking-card"
       class="flex-shrink-0 bg-primary-container text-on-primary-container px-6 py-3 rounded-xl font-headline font-bold text-sm active:scale-[0.98] transition-transform">
      <%= @property.instant_book? && StripeConfig.configured? ? "Book now" : "Request to book" %>
    </a>
  </div>
</div>
