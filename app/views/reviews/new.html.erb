<% content_for(:title, "Write a Review - Crewbase") %>

<section class="max-w-screen-md mx-auto px-6 py-12">
  <h1 class="font-headline text-3xl font-extrabold text-on-surface tracking-tight mb-8">Write a Review</h1>

  <%# Property / Booking Context %>
  <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/15 p-6 mb-8">
    <div class="flex items-center gap-4">
      <% if @property.images.attached? %>
        <%= image_tag @property.images.first, class: "w-16 h-16 rounded-xl object-cover" %>
      <% else %>
        <div class="w-16 h-16 rounded-xl bg-surface-container flex items-center justify-center">
          <span class="material-symbols-outlined text-2xl text-on-surface-variant/30">apartment</span>
        </div>
      <% end %>
      <div>
        <h2 class="font-headline font-bold text-on-surface"><%= @property.title %></h2>
        <p class="text-sm text-on-surface-variant flex items-center gap-1">
          <span class="material-symbols-outlined text-base">location_on</span>
          <%= @property.city %>, <%= @property.country %>
        </p>
        <% if @booking.present? %>
          <p class="text-xs text-on-surface-variant mt-1">
            Stayed <%= @booking.check_in.strftime("%b %d") %> &mdash; <%= @booking.check_out.strftime("%b %d, %Y") %>
          </p>
        <% end %>
      </div>
    </div>
  </div>

  <%# Review Form %>
  <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/15 p-8">
    <% form_url = @booking.present? ? booking_reviews_path(@booking) : property_reviews_path(@property) %>
    <%= form_with(model: @review, url: form_url, class: "space-y-8") do |f| %>
      <%# Error Messages %>
      <% if @review.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-xl p-4">
          <div class="flex items-center gap-2 mb-2">
            <span class="material-symbols-outlined text-red-600">error</span>
            <h3 class="text-sm font-bold text-red-800">Please fix the following errors:</h3>
          </div>
          <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
            <% @review.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Star Rating %>
      <div>
        <label class="block text-sm font-medium text-on-surface mb-3">Your Rating</label>
        <div class="flex items-center gap-1" data-controller="star-rating">
          <% (1..5).each do |star| %>
            <label class="cursor-pointer">
              <%= f.radio_button :rating, star,
                  class: "sr-only peer",
                  data: { star_rating_target: "input", action: "change->star-rating#update" } %>
              <span class="material-symbols-outlined text-3xl transition-colors duration-150 peer-checked:text-yellow-500 text-on-surface-variant/30 hover:text-yellow-400"
                    data-star-rating-target="star"
                    data-value="<%= star %>"
                    style="font-variation-settings: 'FILL' 1;">
                star
              </span>
            </label>
          <% end %>
          <span class="ml-3 text-sm text-on-surface-variant" data-star-rating-target="label">Select a rating</span>
        </div>
      </div>

      <%# Comment %>
      <div>
        <%= f.label :comment, class: "block text-sm font-medium text-on-surface mb-2" do %>
          Your Review
        <% end %>
        <%= f.text_area :comment,
            rows: 6,
            class: "w-full border border-outline-variant/30 rounded-xl px-4 py-3 text-on-surface bg-surface-container-lowest focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-primary-container transition-colors resize-none",
            placeholder: "Share your experience... How was the property? Was it good for remote work? Would you recommend it?" %>
        <p class="text-xs text-on-surface-variant mt-1">Minimum 10 characters recommended</p>
      </div>

      <%# Submit %>
      <div class="flex items-center gap-4 pt-2">
        <%= f.submit "Submit Review",
            class: "bg-primary-container text-on-primary-container px-8 py-3 rounded-xl font-bold active:scale-95 transition-transform cursor-pointer" %>
        <% if @booking.present? %>
          <%= link_to "Cancel", booking_path(@booking), class: "text-sm text-on-surface-variant hover:text-on-surface transition-colors" %>
        <% else %>
          <%= link_to "Cancel", property_path(@property), class: "text-sm text-on-surface-variant hover:text-on-surface transition-colors" %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
