<% content_for(:page_title, "Booking Requests") %>

<%# Header %>
<div class="flex items-center justify-between mb-8">
  <div>
    <h2 class="font-headline text-2xl font-extrabold text-ink tracking-tight">Booking Requests</h2>
    <p class="text-muted mt-1">Manage incoming bookings for your properties.</p>
  </div>
</div>

<%# Bookings Table %>
<% if @bookings.any? %>
  <div class="bg-white rounded-2xl border border-line overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-line text-left">
            <th class="px-6 py-4 text-xs font-medium text-muted uppercase tracking-widest">Guest</th>
            <th class="px-6 py-4 text-xs font-medium text-muted uppercase tracking-widest">Property</th>
            <th class="px-6 py-4 text-xs font-medium text-muted uppercase tracking-widest">Dates</th>
            <th class="px-6 py-4 text-xs font-medium text-muted uppercase tracking-widest">Guests</th>
            <th class="px-6 py-4 text-xs font-medium text-muted uppercase tracking-widest">Total</th>
            <th class="px-6 py-4 text-xs font-medium text-muted uppercase tracking-widest">Status</th>
            <th class="px-6 py-4 text-xs font-medium text-muted uppercase tracking-widest">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-line">
          <% @bookings.each do |booking| %>
            <tr class="hover:bg-neutral-100 transition-colors">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <% if booking.user.avatar.attached? %>
                    <%= image_tag booking.user.avatar, class: "w-8 h-8 rounded-full object-cover" %>
                  <% else %>
                    <div class="w-8 h-8 rounded-full bg-brand flex items-center justify-center">
                      <span class="text-white text-xs font-bold"><%= booking.user.email[0].upcase %></span>
                    </div>
                  <% end %>
                  <span class="font-medium text-ink">
                    <%= booking.user.first_name.present? ? "#{booking.user.first_name} #{booking.user.last_name}" : booking.user.email %>
                  </span>
                </div>
              </td>
              <td class="px-6 py-4 text-muted"><%= truncate(booking.property.title, length: 25) %></td>
              <td class="px-6 py-4 text-muted whitespace-nowrap">
                <%= booking.check_in.strftime("%b %d") %> &mdash; <%= booking.check_out.strftime("%b %d, %Y") %>
              </td>
              <td class="px-6 py-4 text-muted text-center"><%= booking.guests_count %></td>
              <td class="px-6 py-4 font-medium text-ink whitespace-nowrap">&euro;<%= number_with_delimiter(booking.total_price, delimiter: ",") %></td>
              <td class="px-6 py-4">
                <% badge_classes = case booking.status
                   when "pending" then "bg-yellow-100 text-yellow-800"
                   when "confirmed" then "bg-green-100 text-green-800"
                   when "cancelled" then "bg-red-100 text-red-800"
                   when "completed" then "bg-blue-100 text-blue-800"
                   end %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold <%= badge_classes %>">
                  <%= booking.status.capitalize %>
                </span>
              </td>
              <td class="px-6 py-4">
                <div class="flex items-center gap-2">
                  <% if booking.pending? %>
                    <%= button_to host_booking_path(booking),
                        method: :patch,
                        params: { booking: { status: "confirmed" } },
                        class: "inline-flex items-center gap-1 bg-green-100 text-green-800 px-3 py-1.5 rounded-lg text-xs font-semibold hover:bg-green-200 transition-colors" do %>
                      <span class="material-symbols-outlined text-sm">check</span>
                      Approve
                    <% end %>

                    <%= button_to host_booking_path(booking),
                        method: :patch,
                        params: { booking: { status: "cancelled" } },
                        class: "inline-flex items-center gap-1 bg-red-100 text-red-800 px-3 py-1.5 rounded-lg text-xs font-semibold hover:bg-red-200 transition-colors",
                        data: { turbo_confirm: "Are you sure you want to reject this booking?" } do %>
                      <span class="material-symbols-outlined text-sm">close</span>
                      Reject
                    <% end %>
                  <% end %>

                  <%= link_to host_booking_path(booking),
                      class: "inline-flex items-center gap-1 text-brand hover:underline text-xs font-medium" do %>
                    <span class="material-symbols-outlined text-sm">visibility</span>
                    View
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# Pagination %>
  <div class="mt-8 flex justify-center">
    <%== pagy_nav(@pagy) %>
  </div>
<% else %>
  <div class="text-center py-20 bg-white rounded-2xl border border-line">
    <span class="material-symbols-outlined text-6xl text-muted/30 mb-4">calendar_month</span>
    <h3 class="font-headline text-xl font-bold text-ink mb-2">No booking requests</h3>
    <p class="text-muted">When guests book your properties, they will appear here.</p>
  </div>
<% end %>
