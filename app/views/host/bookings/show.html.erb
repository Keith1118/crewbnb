<% content_for(:page_title, "Booking Details") %>

<%# Breadcrumb %>
<nav class="flex items-center gap-2 text-sm text-muted mb-8">
  <%= link_to "Bookings", host_bookings_path, class: "hover:text-brand transition-colors" %>
  <span class="material-symbols-outlined text-base">chevron_right</span>
  <span class="text-ink font-medium"><%= @booking.invoice_reference %></span>
</nav>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <%# Main Detail %>
  <div class="lg:col-span-2 space-y-6">
    <%# Booking Info Card %>
    <div class="bg-white rounded-2xl border border-line p-8">
      <div class="flex items-start justify-between mb-6">
        <div>
          <h2 class="font-headline text-xl font-extrabold text-ink tracking-tight mb-1">
            <%= @booking.property.title %>
          </h2>
          <p class="text-sm text-muted font-mono"><%= @booking.invoice_reference %></p>
        </div>

        <% badge_classes = case @booking.status
           when "pending" then "bg-yellow-100 text-yellow-800 border-yellow-200"
           when "confirmed" then "bg-green-100 text-green-800 border-green-200"
           when "cancelled" then "bg-red-100 text-red-800 border-red-200"
           when "completed" then "bg-blue-100 text-blue-800 border-blue-200"
           end %>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold border <%= badge_classes %>">
          <%= @booking.status.capitalize %>
        </span>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
        <div>
          <p class="text-xs font-medium text-muted uppercase tracking-widest mb-1">Check-in</p>
          <p class="font-headline font-bold text-ink"><%= @booking.check_in.strftime("%a, %b %d, %Y") %></p>
        </div>
        <div>
          <p class="text-xs font-medium text-muted uppercase tracking-widest mb-1">Check-out</p>
          <p class="font-headline font-bold text-ink"><%= @booking.check_out.strftime("%a, %b %d, %Y") %></p>
        </div>
        <div>
          <p class="text-xs font-medium text-muted uppercase tracking-widest mb-1">Duration</p>
          <p class="font-headline font-bold text-ink"><%= pluralize(@booking.nights, "night") %></p>
        </div>
        <div>
          <p class="text-xs font-medium text-muted uppercase tracking-widest mb-1">Guests</p>
          <p class="font-headline font-bold text-ink"><%= pluralize(@booking.guests_count, "guest") %></p>
        </div>
        <div>
          <p class="text-xs font-medium text-muted uppercase tracking-widest mb-1">Total Price</p>
          <p class="font-headline text-xl font-extrabold text-ink">&euro;<%= number_with_delimiter(@booking.total_price, delimiter: ",") %></p>
        </div>
      </div>

      <% if @booking.special_requests.present? %>
        <div class="mt-6 pt-6 border-t border-line">
          <p class="text-xs font-medium text-muted uppercase tracking-widest mb-2">Special Requests</p>
          <p class="text-ink text-sm leading-relaxed"><%= @booking.special_requests %></p>
        </div>
      <% end %>
    </div>

    <%# Invoice %>
    <% unless @booking.cancelled? %>
      <div>
        <%= link_to invoice_booking_path(@booking), target: "_blank",
            class: "inline-flex items-center gap-2 border border-line text-ink px-5 py-2.5 rounded-xl font-bold text-sm hover:bg-neutral-100 active:scale-95 transition-all" do %>
          <span class="material-symbols-outlined text-lg" aria-hidden="true">receipt_long</span>
          View / print invoice
        <% end %>
      </div>
    <% end %>

    <%# Action Buttons for Pending Bookings %>
    <% if @booking.pending? %>
      <div class="flex items-center gap-3">
        <%= button_to host_booking_path(@booking),
            method: :patch,
            params: { booking: { status: "confirmed" } },
            class: "inline-flex items-center gap-2 bg-green-600 text-white px-6 py-3 rounded-xl font-bold active:scale-95 transition-transform" do %>
          <span class="material-symbols-outlined text-lg">check_circle</span>
          Approve Booking
        <% end %>

        <%= button_to host_booking_path(@booking),
            method: :patch,
            params: { booking: { status: "cancelled" } },
            class: "inline-flex items-center gap-2 border border-red-300 text-red-700 px-6 py-3 rounded-xl font-bold hover:bg-red-50 active:scale-95 transition-all",
            data: { turbo_confirm: "Are you sure you want to reject this booking?" } do %>
          <span class="material-symbols-outlined text-lg">cancel</span>
          Reject Booking
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Sidebar: Payout + Guest Info %>
  <div class="space-y-6">
    <%# Your payout %>
    <div class="bg-white rounded-2xl border border-line p-6">
      <h3 class="font-headline font-bold text-ink mb-4">Your payout</h3>
      <div class="space-y-2.5 text-sm">
        <div class="flex justify-between">
          <span class="text-muted">Booking total</span>
          <span class="text-ink font-medium"><%= number_to_currency(@booking.total_price, precision: 2) %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-muted">Crewbnb commission (7.5%)</span>
          <span class="text-ink">&minus;<%= number_to_currency(@booking.commission_amount, precision: 2) %></span>
        </div>
        <div class="flex justify-between pt-2.5 border-t border-line">
          <span class="font-bold text-ink">You receive</span>
          <span class="font-headline font-extrabold text-ink"><%= number_to_currency(@booking.host_payout, precision: 2) %></span>
        </div>
      </div>
      <p class="text-xs text-muted mt-3">The guest pays the full total — commission comes out of your payout, not added on top.</p>
    </div>

    <%# Guest info %>
    <div class="bg-white rounded-2xl border border-line p-6">
      <h3 class="font-headline font-bold text-ink mb-4">Guest Information</h3>
      <div class="flex items-center gap-4 mb-4">
        <% guest = @booking.user %>
        <% if guest.avatar.attached? %>
          <%= image_tag guest.avatar, class: "w-14 h-14 rounded-full object-cover" %>
        <% else %>
          <div class="w-14 h-14 rounded-full bg-brand flex items-center justify-center">
            <span class="text-white text-xl font-bold"><%= guest.email[0].upcase %></span>
          </div>
        <% end %>
        <div>
          <p class="font-headline font-bold text-ink">
            <%= guest.first_name.present? ? "#{guest.first_name} #{guest.last_name}" : guest.email %>
          </p>
          <p class="text-sm text-muted"><%= guest.email %></p>
        </div>
      </div>

      <% if guest.phone.present? %>
        <div class="flex items-center gap-2 text-sm text-muted mb-3">
          <span class="material-symbols-outlined text-base">phone</span>
          <%= guest.phone %>
        </div>
      <% end %>

      <p class="text-xs text-muted">
        Member since <%= guest.created_at.strftime("%B %Y") %>
      </p>

      <div class="mt-4 pt-4 border-t border-line">
        <%= link_to conversations_path(recipient_id: guest.id, property_id: @booking.property.id),
            class: "flex items-center justify-center gap-2 w-full border border-line text-muted px-4 py-2.5 rounded-xl text-sm font-medium hover:bg-neutral-100 transition-colors" do %>
          <span class="material-symbols-outlined text-lg">chat</span>
          Message Guest
        <% end %>
      </div>
    </div>
  </div>
</div>
