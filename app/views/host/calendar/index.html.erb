<% content_for(:page_title, "Calendar") %>
<% content_for(:title, "Calendar - Crewbase Host") %>

<% if @property.nil? %>
  <%# Calm empty state — no pushy "list your first property" CTA %>
  <div class="text-center py-20 bg-white rounded-2xl border border-line">
    <span class="material-symbols-outlined text-6xl text-neutral-300">calendar_month</span>
    <h3 class="font-headline text-lg font-bold text-ink mt-4">No listings to show</h3>
    <p class="text-muted mt-2 max-w-md mx-auto">
      Your availability calendar appears here once you have a listing.
    </p>
  </div>
<% else %>
  <div class="space-y-6" data-controller="calendar">
    <%# ===== Header: property switcher + stats ===== %>
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-3xl text-brand">calendar_month</span>
        <div>
          <h2 class="font-headline text-2xl font-extrabold text-ink tracking-tight">Availability Calendar</h2>
          <p class="text-sm text-muted mt-0.5">Block dates, track bookings and manage your open nights.</p>
        </div>
      </div>

      <%# Property switcher %>
      <%= form_with url: host_calendar_path, method: :get, class: "min-w-[240px]" do |f| %>
        <%= hidden_field_tag :month, @month.strftime("%Y-%m") %>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-lg text-muted pointer-events-none">apartment</span>
          <%= select_tag :property_id,
                options_for_select(@properties.map { |p| [p.title, p.id] }, @property.id),
                onchange: "this.form.requestSubmit()",
                class: "w-full appearance-none pl-10 pr-9 py-2.5 rounded-xl bg-white border border-neutral-300 text-sm font-semibold text-ink focus:outline-none focus:ring-2 focus:ring-brand/40 cursor-pointer" %>
          <span class="material-symbols-outlined absolute right-2.5 top-1/2 -translate-y-1/2 text-lg text-muted pointer-events-none">expand_more</span>
        </div>
      <% end %>
    </div>

    <%# ===== Stat tiles ===== %>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="bg-white rounded-2xl border border-line p-5">
        <p class="text-xs font-bold text-muted uppercase tracking-wider">Booked nights</p>
        <p class="font-headline text-3xl font-extrabold text-ink mt-1"><%= @booked_dates.size %></p>
        <p class="text-xs text-muted mt-1"><%= @pending_dates.size %> pending</p>
      </div>
      <div class="bg-white rounded-2xl border border-line p-5">
        <p class="text-xs font-bold text-muted uppercase tracking-wider">Open nights</p>
        <p class="font-headline text-3xl font-extrabold text-ink mt-1"><%= @open_in_month %></p>
        <p class="text-xs text-muted mt-1">available to book</p>
      </div>
      <div class="bg-white rounded-2xl border border-line p-5">
        <p class="text-xs font-bold text-muted uppercase tracking-wider">Blocked</p>
        <p class="font-headline text-3xl font-extrabold text-ink mt-1"><%= @blocked_in_month %></p>
        <p class="text-xs text-muted mt-1">nights closed</p>
      </div>
      <div class="bg-white rounded-2xl border border-line p-5">
        <p class="text-xs font-bold text-muted uppercase tracking-wider">Your earnings</p>
        <p class="font-headline text-3xl font-extrabold text-brand mt-1"><%= number_to_currency(@revenue_month, precision: 0) %></p>
        <p class="text-xs text-muted mt-1">this month, after 7.5% fee</p>
      </div>
    </div>

    <%# ===== Calendar card ===== %>
    <div class="bg-white rounded-2xl border border-line overflow-hidden">
      <%# Month navigation %>
      <div class="flex items-center justify-between px-6 py-4 border-b border-line">
        <h3 class="font-headline text-lg font-bold text-ink"><%= @month.strftime("%B %Y") %></h3>
        <div class="flex items-center gap-1">
          <%= link_to host_calendar_path(property_id: @property.id, month: (@month << 1).strftime("%Y-%m")),
                class: "p-2 rounded-lg hover:bg-neutral-100 text-muted hover:text-ink transition-colors", title: "Previous month" do %>
            <span class="material-symbols-outlined text-xl">chevron_left</span>
          <% end %>
          <%= link_to "Today", host_calendar_path(property_id: @property.id, month: Date.current.strftime("%Y-%m")),
                class: "px-3 py-1.5 rounded-lg text-sm font-semibold text-muted hover:bg-neutral-100 hover:text-ink transition-colors" %>
          <%= link_to host_calendar_path(property_id: @property.id, month: (@month >> 1).strftime("%Y-%m")),
                class: "p-2 rounded-lg hover:bg-neutral-100 text-muted hover:text-ink transition-colors", title: "Next month" do %>
            <span class="material-symbols-outlined text-xl">chevron_right</span>
          <% end %>
        </div>
      </div>

      <%# Weekday headers %>
      <div class="grid grid-cols-7 border-b border-line">
        <% %w[Mon Tue Wed Thu Fri Sat Sun].each do |wd| %>
          <div class="px-2 py-3 text-center text-xs font-bold text-muted uppercase tracking-wider"><%= wd %></div>
        <% end %>
      </div>

      <%# Day grid %>
      <div class="grid grid-cols-7">
        <% (@grid_start..@grid_end).each do |date| %>
          <%
            in_month = date.month == @month.month
            booking  = @bookings_by_date[date]
            blocked  = @blocked.include?(date)
            past     = date < Date.current
            today    = date == Date.current
            price    = @custom_prices[date] || @property.price_per_night
            base_cell = "relative min-h-[92px] p-2 border-b border-r border-line flex flex-col"
          %>

          <% if !in_month %>
            <%# Adjacent-month filler %>
            <div class="<%= base_cell %> bg-neutral-50">
              <span class="text-xs text-neutral-300"><%= date.day %></span>
            </div>

          <% elsif booking %>
            <%# Booked — links through to the booking %>
            <%
              confirmed = booking.confirmed?
              tint = confirmed ? "bg-brand/10 hover:bg-brand/20" : "bg-amber-400/10 hover:bg-amber-400/20"
              dot  = confirmed ? "bg-brand" : "bg-amber-500"
              is_start = booking.check_in == date
            %>
            <%= link_to host_booking_path(booking), class: "#{base_cell} #{tint} transition-colors group", title: "#{booking.user.first_name} · #{booking.status}" do %>
              <span class="text-xs font-semibold <%= today ? 'text-brand' : 'text-ink' %>"><%= date.day %></span>
              <% if is_start %>
                <div class="mt-auto">
                  <div class="flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full <%= dot %>"></span>
                    <span class="text-xs font-semibold text-ink truncate"><%= booking.user.first_name.presence || "Guest" %></span>
                  </div>
                  <span class="text-[10px] uppercase tracking-wider font-bold <%= confirmed ? 'text-brand' : 'text-amber-600' %>"><%= booking.status %></span>
                </div>
              <% else %>
                <span class="mt-auto text-[10px] text-muted">booked</span>
              <% end %>
            <% end %>

          <% elsif blocked %>
            <%# Blocked — click to reopen (unless past) %>
            <% if past %>
              <div class="<%= base_cell %> bg-neutral-50">
                <span class="text-xs text-muted"><%= date.day %></span>
                <span class="mt-auto text-[10px] text-muted">blocked</span>
              </div>
            <% else %>
              <%= button_to host_calendar_toggle_path(property_id: @property.id, date: date.iso8601, month: @month.strftime("%Y-%m")),
                    method: :patch,
                    class: "#{base_cell} text-left w-full bg-[repeating-linear-gradient(45deg,transparent,transparent_6px,rgba(0,0,0,0.04)_6px,rgba(0,0,0,0.04)_12px)] hover:bg-neutral-100 cursor-pointer",
                    title: "Click to reopen this date" do %>
                <span class="text-xs font-semibold <%= today ? 'text-brand' : 'text-muted' %>"><%= date.day %></span>
                <span class="mt-auto inline-flex items-center gap-1 text-[10px] font-bold uppercase tracking-wider text-muted">
                  <span class="material-symbols-outlined text-sm">lock</span> Blocked
                </span>
              <% end %>
            <% end %>

          <% else %>
            <%# Open %>
            <% if past %>
              <div class="<%= base_cell %>">
                <span class="text-xs text-neutral-300"><%= date.day %></span>
              </div>
            <% else %>
              <%= button_to host_calendar_toggle_path(property_id: @property.id, date: date.iso8601, month: @month.strftime("%Y-%m")),
                    method: :patch,
                    class: "#{base_cell} text-left w-full hover:bg-neutral-100 cursor-pointer group #{today ? 'ring-1 ring-inset ring-brand/40' : ''}",
                    title: "Click to block this date" do %>
                <span class="text-xs font-semibold <%= today ? 'text-brand' : 'text-ink' %>"><%= date.day %></span>
                <span class="mt-auto text-xs font-semibold text-muted"><%= number_to_currency(price, precision: 0) %></span>
                <span class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity material-symbols-outlined text-sm text-muted">block</span>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# ===== Legend + bulk range block ===== %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
      <%# Legend %>
      <div class="bg-white rounded-2xl border border-line p-5">
        <p class="text-xs font-bold text-muted uppercase tracking-wider mb-3">Legend</p>
        <ul class="space-y-2 text-sm text-ink">
          <li class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-brand"></span> Confirmed booking</li>
          <li class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-amber-400"></span> Pending request</li>
          <li class="flex items-center gap-2"><span class="w-3 h-3 rounded bg-[repeating-linear-gradient(45deg,#bbb,#bbb_2px,#eee_2px,#eee_4px)]"></span> Blocked by you</li>
          <li class="flex items-center gap-2"><span class="w-3 h-3 rounded border border-neutral-300"></span> Open — click a day to block</li>
        </ul>
      </div>

      <%# Bulk range block/open %>
      <div class="bg-white rounded-2xl border border-line p-5 lg:col-span-2">
        <p class="text-xs font-bold text-muted uppercase tracking-wider mb-3">Block or open a range</p>
        <%= form_with url: host_calendar_block_range_path, method: :patch, class: "flex flex-col sm:flex-row sm:items-end gap-3" do |f| %>
          <%= hidden_field_tag :property_id, @property.id %>
          <div class="flex-1">
            <label class="block text-xs font-semibold text-muted mb-1">From</label>
            <%= date_field_tag :from, Date.current.iso8601, min: Date.current.iso8601,
                  class: "w-full px-3 py-2.5 rounded-xl bg-white border border-neutral-300 text-sm text-ink focus:outline-none focus:ring-2 focus:ring-brand/40" %>
          </div>
          <div class="flex-1">
            <label class="block text-xs font-semibold text-muted mb-1">To</label>
            <%= date_field_tag :to, Date.current.iso8601, min: Date.current.iso8601,
                  class: "w-full px-3 py-2.5 rounded-xl bg-white border border-neutral-300 text-sm text-ink focus:outline-none focus:ring-2 focus:ring-brand/40" %>
          </div>
          <div class="flex gap-2">
            <%= button_tag name: "range_action", value: "block", type: "submit",
                  class: "inline-flex items-center gap-1.5 bg-ink text-white px-4 py-2.5 rounded-xl font-bold text-sm active:scale-95 transition-transform" do %>
              <span class="material-symbols-outlined text-lg">lock</span> Block
            <% end %>
            <%= button_tag name: "range_action", value: "open", type: "submit",
                  class: "inline-flex items-center gap-1.5 bg-neutral-100 text-ink px-4 py-2.5 rounded-xl font-bold text-sm active:scale-95 transition-transform border border-neutral-300" do %>
              <span class="material-symbols-outlined text-lg">lock_open</span> Open
            <% end %>
          </div>
        <% end %>
        <p class="text-xs text-muted mt-3">Dates that already have a booking are skipped automatically.</p>
      </div>
    </div>
  </div>
<% end %>
