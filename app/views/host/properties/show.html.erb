<% content_for(:page_title, @property.title) %>
<% content_for(:title, "#{@property.title} - Crewbase Host") %>

<%# Deterministic gradient %>
<% hue_1 = (@property.id * 37) % 360 %>
<% hue_2 = (hue_1 + 40) % 360 %>

<div class="space-y-8">
  <%# Header with Actions %>
  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
    <div class="flex items-start gap-3">
      <%= link_to host_properties_path, class: "p-2 rounded-lg hover:bg-neutral-100 transition-colors text-muted mt-0.5" do %>
        <span class="material-symbols-outlined text-xl">arrow_back</span>
      <% end %>
      <div>
        <h2 class="font-headline text-2xl font-extrabold text-ink tracking-tight"><%= @property.title %></h2>
        <div class="flex items-center gap-2 mt-1">
          <span class="material-symbols-outlined text-muted text-base">location_on</span>
          <p class="text-sm text-muted"><%= [@property.city, @property.country].compact.join(", ") %></p>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-3 ml-12 sm:ml-0">
      <%# Status Badge %>
      <% status_styles = {
        "draft" => "bg-neutral-100 text-muted",
        "published" => "bg-brand/15 text-brand",
        "archived" => "bg-error-container/20 text-error"
      } %>
      <span class="inline-flex items-center px-3 py-1.5 rounded-xl text-xs font-bold uppercase tracking-wider <%= status_styles[@property.status] || status_styles['draft'] %>">
        <span class="material-symbols-outlined text-sm mr-1">
          <%= case @property.status
              when "published" then "public"
              when "archived" then "archive"
              else "edit_note"
              end %>
        </span>
        <%= @property.status %>
      </span>

      <%# Edit Button %>
      <%= link_to edit_host_property_path(@property), class: "inline-flex items-center gap-2 bg-brand text-white px-5 py-2.5 rounded-xl font-bold text-sm active:scale-95 transition-transform" do %>
        <span class="material-symbols-outlined text-lg">edit</span>
        Edit
      <% end %>

      <%# View Public Listing %>
      <%= link_to property_path(@property), target: "_blank", class: "inline-flex items-center gap-2 border border-line text-muted px-5 py-2.5 rounded-xl font-bold text-sm hover:bg-neutral-100 transition-colors" do %>
        <span class="material-symbols-outlined text-lg">open_in_new</span>
        View Listing
      <% end %>
    </div>
  </div>

  <%# Property Image Banner %>
  <div class="rounded-2xl overflow-hidden aspect-[3/1]">
    <% if @property.images.attached? %>
      <%= image_tag @property.images.first, class: "w-full h-full object-cover" %>
    <% else %>
      <div class="w-full h-full flex items-center justify-center" style="background: linear-gradient(135deg, hsl(<%= hue_1 %>, 45%, 35%) 0%, hsl(<%= hue_2 %>, 55%, 25%) 100%);">
        <span class="material-symbols-outlined text-white/30 text-6xl">image</span>
      </div>
    <% end %>
  </div>

  <%# Stats Row %>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="bg-white rounded-2xl border border-line p-5">
      <div class="flex items-center gap-2 text-muted mb-2">
        <span class="material-symbols-outlined text-lg">payments</span>
        <span class="text-xs font-bold uppercase tracking-wider">Price</span>
      </div>
      <p class="font-headline text-xl font-extrabold text-ink"><%= number_to_currency(@property.price_per_night) %><span class="text-sm font-normal text-muted">/night</span></p>
    </div>
    <div class="bg-white rounded-2xl border border-line p-5">
      <div class="flex items-center gap-2 text-muted mb-2">
        <span class="material-symbols-outlined text-lg">calendar_month</span>
        <span class="text-xs font-bold uppercase tracking-wider">Bookings</span>
      </div>
      <p class="font-headline text-xl font-extrabold text-ink"><%= @property.bookings.count %></p>
    </div>
    <div class="bg-white rounded-2xl border border-line p-5">
      <div class="flex items-center gap-2 text-muted mb-2">
        <span class="material-symbols-outlined text-lg">star</span>
        <span class="text-xs font-bold uppercase tracking-wider">Rating</span>
      </div>
      <p class="font-headline text-xl font-extrabold text-ink">
        <%= @property.average_rating || "--" %>
        <% if @property.reviews.any? %>
          <span class="text-sm font-normal text-muted">(<%= @property.reviews.count %>)</span>
        <% end %>
      </p>
    </div>
    <div class="bg-white rounded-2xl border border-line p-5">
      <div class="flex items-center gap-2 text-muted mb-2">
        <span class="material-symbols-outlined text-lg">favorite</span>
        <span class="text-xs font-bold uppercase tracking-wider">Favorites</span>
      </div>
      <p class="font-headline text-xl font-extrabold text-ink"><%= @property.favorites.count %></p>
    </div>
  </div>

  <%# Details Grid %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Left: Property Details %>
    <div class="lg:col-span-2 space-y-6">
      <%# Description %>
      <div class="bg-white rounded-2xl border border-line p-6">
        <h3 class="font-headline text-lg font-bold text-ink mb-3">Description</h3>
        <p class="text-sm text-muted leading-relaxed whitespace-pre-line"><%= @property.description %></p>
      </div>

      <%# Property Specs %>
      <div class="bg-white rounded-2xl border border-line p-6">
        <h3 class="font-headline text-lg font-bold text-ink mb-4">Property Details</h3>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-brand text-xl">apartment</span>
            <div>
              <p class="text-xs text-muted">Type</p>
              <p class="text-sm font-semibold text-ink"><%= @property.property_type || "N/A" %></p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-brand text-xl">bed</span>
            <div>
              <p class="text-xs text-muted">Bedrooms</p>
              <p class="text-sm font-semibold text-ink"><%= @property.bedrooms %></p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-brand text-xl">bathroom</span>
            <div>
              <p class="text-xs text-muted">Bathrooms</p>
              <p class="text-sm font-semibold text-ink"><%= @property.bathrooms %></p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-brand text-xl">group</span>
            <div>
              <p class="text-xs text-muted">Max Guests</p>
              <p class="text-sm font-semibold text-ink"><%= @property.max_guests %></p>
            </div>
          </div>
        </div>
      </div>

      <%# Work Features %>
      <div class="bg-white rounded-2xl border border-line p-6">
        <h3 class="font-headline text-lg font-bold text-ink mb-4">Work Features</h3>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          <% work_features = [
            { icon: "desk", label: "Dedicated Desk", enabled: @property.has_desk? },
            { icon: "meeting_room", label: "Meeting Room", enabled: @property.has_meeting_room? },
            { icon: "print", label: "Printer", enabled: @property.has_printer? },
            { icon: "local_parking", label: "Parking", enabled: @property.has_parking? },
            { icon: "bolt", label: "Instant Book", enabled: @property.instant_book? }
          ] %>
          <% work_features.each do |feature| %>
            <div class="flex items-center gap-2 p-3 rounded-xl <%= feature[:enabled] ? 'bg-brand/10' : 'bg-neutral-100' %>">
              <span class="material-symbols-outlined text-lg <%= feature[:enabled] ? 'text-brand' : 'text-neutral-400' %>"><%= feature[:icon] %></span>
              <span class="text-sm <%= feature[:enabled] ? 'font-semibold text-ink' : 'text-muted' %>"><%= feature[:label] %></span>
            </div>
          <% end %>
          <% if @property.wifi_speed.present? %>
            <div class="flex items-center gap-2 p-3 rounded-xl bg-brand/10">
              <span class="material-symbols-outlined text-lg text-brand">wifi</span>
              <span class="text-sm font-semibold text-ink"><%= @property.wifi_speed %></span>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# Right: Recent Bookings %>
    <div class="lg:col-span-1 space-y-6">
      <%# Quick Actions %>
      <div class="bg-white rounded-2xl border border-line p-6">
        <h3 class="font-headline text-lg font-bold text-ink mb-4">Quick Actions</h3>
        <div class="space-y-2">
          <%= link_to edit_host_property_path(@property), class: "flex items-center gap-3 p-3 rounded-xl hover:bg-neutral-100 transition-colors w-full text-left" do %>
            <span class="material-symbols-outlined text-brand text-xl">edit</span>
            <span class="text-sm font-medium text-ink">Edit Property</span>
          <% end %>
          <%= link_to property_path(@property), target: "_blank", class: "flex items-center gap-3 p-3 rounded-xl hover:bg-neutral-100 transition-colors w-full text-left" do %>
            <span class="material-symbols-outlined text-brand text-xl">open_in_new</span>
            <span class="text-sm font-medium text-ink">View Public Listing</span>
          <% end %>
          <%= button_to host_property_path(@property), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this property?" }, class: "flex items-center gap-3 p-3 rounded-xl hover:bg-error-container/20 transition-colors w-full text-left cursor-pointer" do %>
            <span class="material-symbols-outlined text-error text-xl">delete</span>
            <span class="text-sm font-medium text-error">Delete Property</span>
          <% end %>
        </div>
      </div>

      <%# Recent Bookings %>
      <div class="bg-white rounded-2xl border border-line p-6">
        <h3 class="font-headline text-lg font-bold text-ink mb-4">Recent Bookings</h3>
        <% recent_bookings = @property.bookings.order(created_at: :desc).limit(5) %>
        <% if recent_bookings.any? %>
          <div class="space-y-3">
            <% recent_bookings.each do |booking| %>
              <% booking_status_styles = {
                "pending" => "bg-amber-100 text-amber-800",
                "confirmed" => "bg-brand/15 text-brand",
                "cancelled" => "bg-error-container/20 text-error",
                "completed" => "bg-green-100 text-green-800"
              } %>
              <%= link_to host_booking_path(booking), class: "block p-3 rounded-xl hover:bg-neutral-100 transition-colors border border-line" do %>
                <div class="flex items-center justify-between mb-1">
                  <span class="text-sm font-semibold text-ink"><%= booking.user.first_name || booking.user.email.split("@").first %></span>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-bold uppercase tracking-wider <%= booking_status_styles[booking.status] || '' %>"><%= booking.status %></span>
                </div>
                <div class="flex items-center gap-1 text-xs text-muted">
                  <span class="material-symbols-outlined text-sm">calendar_today</span>
                  <span><%= booking.check_in.strftime("%b %d") %> - <%= booking.check_out.strftime("%b %d, %Y") %></span>
                </div>
                <div class="flex items-center gap-1 text-xs text-muted mt-0.5">
                  <span class="material-symbols-outlined text-sm">payments</span>
                  <span><%= number_to_currency(booking.total_price) %></span>
                </div>
              <% end %>
            <% end %>
          </div>
          <% if @property.bookings.count > 5 %>
            <%= link_to host_bookings_path, class: "block text-center text-sm font-bold text-brand mt-4 hover:underline" do %>
              View all bookings
            <% end %>
          <% end %>
        <% else %>
          <div class="text-center py-6">
            <span class="material-symbols-outlined text-3xl text-neutral-300">event_busy</span>
            <p class="text-xs text-muted mt-2">No bookings yet</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
