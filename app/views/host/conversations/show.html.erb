<% content_for(:page_title, "Inbox") %>
<% content_for(:title, "Conversation with #{@guest.first_name.presence || @guest.email} - Crewbase Host") %>

<%= link_to host_conversations_path, class: "inline-flex items-center gap-1.5 text-sm font-semibold text-muted hover:text-ink mb-4" do %>
  <span class="material-symbols-outlined text-lg">arrow_back</span> All messages
<% end %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <%# ===== Thread ===== %>
  <div class="lg:col-span-2">
    <div class="bg-white rounded-2xl border border-line overflow-hidden flex flex-col" style="min-height: 520px;">
      <%# Header %>
      <div class="flex items-center gap-3 px-5 py-4 border-b border-line">
        <% if @guest.avatar.attached? %>
          <%= image_tag @guest.avatar, class: "w-10 h-10 rounded-full object-cover" %>
        <% else %>
          <div class="w-10 h-10 rounded-full bg-brand flex items-center justify-center text-white font-bold"><%= (@guest.first_name.presence || @guest.email)[0].upcase %></div>
        <% end %>
        <div class="min-w-0">
          <h1 class="font-bold text-ink truncate"><%= @guest.first_name.present? ? "#{@guest.first_name} #{@guest.last_name}" : @guest.email %></h1>
          <p class="text-xs text-muted truncate"><%= @conversation.property.title %></p>
        </div>
      </div>

      <%# Messages %>
      <div class="flex-1 px-5 py-6 space-y-4 overflow-y-auto bg-neutral-50" style="max-height: 520px;" id="message-thread">
        <% if @messages.empty? %>
          <div class="text-center py-12">
            <span class="material-symbols-outlined text-4xl text-neutral-300">chat_bubble_outline</span>
            <p class="text-sm text-muted mt-2">No messages yet. Say hello below.</p>
          </div>
        <% else %>
          <% @messages.each do |message| %>
            <% mine = message.user == current_user %>
            <div class="flex <%= mine ? 'justify-end' : 'justify-start' %>">
              <div class="max-w-[78%]">
                <div class="<%= mine ? 'bg-brand text-white rounded-2xl rounded-br-md' : 'bg-white text-ink border border-line rounded-2xl rounded-bl-md' %> px-4 py-2.5">
                  <p class="text-sm leading-relaxed whitespace-pre-wrap"><%= message.body %></p>
                </div>
                <div class="flex items-center gap-1.5 px-1 mt-1 <%= mine ? 'justify-end' : 'justify-start' %>">
                  <span class="text-[10px] text-muted"><%= message.created_at.strftime("%d %b, %H:%M") %></span>
                  <% if mine %>
                    <span class="material-symbols-outlined text-xs <%= message.read? ? 'text-brand' : 'text-neutral-400' %>"><%= message.read? ? "done_all" : "done" %></span>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <%# Reply %>
      <div class="border-t border-line px-4 py-3">
        <%= form_with url: host_conversation_messages_path(@conversation), method: :post, class: "flex items-end gap-2" do |f| %>
          <%= text_area_tag "message[body]", nil, rows: 1, required: true,
              class: "flex-1 border border-neutral-300 rounded-xl px-4 py-2.5 text-sm text-ink bg-white focus:outline-none focus:ring-2 focus:ring-brand/40 resize-none",
              placeholder: "Type a reply…" %>
          <button type="submit" class="abb-btn !px-3 flex-shrink-0" aria-label="Send">
            <span class="material-symbols-outlined">send</span>
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <%# ===== Context panel ===== %>
  <div class="space-y-4">
    <%# Guest %>
    <div class="bg-white rounded-2xl border border-line p-5">
      <p class="text-xs font-bold text-muted uppercase tracking-wider mb-3">Guest</p>
      <div class="flex items-center gap-3">
        <% if @guest.avatar.attached? %>
          <%= image_tag @guest.avatar, class: "w-11 h-11 rounded-full object-cover" %>
        <% else %>
          <div class="w-11 h-11 rounded-full bg-brand flex items-center justify-center text-white font-bold"><%= (@guest.first_name.presence || @guest.email)[0].upcase %></div>
        <% end %>
        <div class="min-w-0">
          <p class="font-bold text-ink truncate"><%= @guest.first_name.present? ? "#{@guest.first_name} #{@guest.last_name}" : @guest.email %></p>
          <p class="text-xs text-muted truncate"><%= @guest.email %></p>
        </div>
      </div>
      <% if @guest.phone.present? %>
        <p class="text-sm text-muted mt-3 flex items-center gap-2"><span class="material-symbols-outlined text-base">call</span><%= @guest.phone %></p>
      <% end %>
    </div>

    <%# Booking context %>
    <div class="bg-white rounded-2xl border border-line p-5">
      <p class="text-xs font-bold text-muted uppercase tracking-wider mb-3">Booking</p>
      <% if @booking %>
        <% badge = case @booking.status
           when "pending" then ["bg-amber-400/15 text-amber-600", "pending"]
           when "confirmed" then ["bg-brand/10 text-brand", "confirmed"]
           when "cancelled" then ["bg-red-100 text-red-700", "cancelled"]
           when "completed" then ["bg-blue-500/10 text-blue-600", "completed"]
           end %>
        <div class="flex items-center justify-between mb-3">
          <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-bold uppercase tracking-wider <%= badge[0] %>"><%= badge[1] %></span>
          <span class="text-xs text-muted font-mono"><%= @booking.invoice_reference %></span>
        </div>
        <div class="space-y-1.5 text-sm">
          <div class="flex justify-between"><span class="text-muted">Check-in</span><span class="text-ink font-medium"><%= @booking.check_in.strftime("%a %d %b") %></span></div>
          <div class="flex justify-between"><span class="text-muted">Check-out</span><span class="text-ink font-medium"><%= @booking.check_out.strftime("%a %d %b") %></span></div>
          <div class="flex justify-between"><span class="text-muted">Guests</span><span class="text-ink font-medium"><%= @booking.guests_count %></span></div>
          <div class="flex justify-between pt-1.5 border-t border-line"><span class="text-muted">Total</span><span class="text-ink font-bold"><%= number_to_currency(@booking.total_price, precision: 0) %></span></div>
        </div>
        <%= link_to host_booking_path(@booking), class: "mt-3 inline-flex items-center gap-1 text-sm font-semibold text-brand hover:underline" do %>
          View booking <span class="material-symbols-outlined text-base">arrow_forward</span>
        <% end %>
      <% else %>
        <p class="text-sm text-muted">No booking from this guest yet.</p>
      <% end %>
    </div>

    <%# Listing %>
    <div class="bg-white rounded-2xl border border-line p-5">
      <p class="text-xs font-bold text-muted uppercase tracking-wider mb-3">Listing</p>
      <%= link_to property_path(@conversation.property), target: "_blank", class: "flex items-center gap-3 group" do %>
        <div class="w-12 h-12 rounded-xl overflow-hidden flex-shrink-0 bg-neutral-100">
          <% if @conversation.property.images.attached? %>
            <%= image_tag sized_image(@conversation.property.images.first, resize_to_fill: [96, 96]), class: "w-full h-full object-cover" %>
          <% end %>
        </div>
        <div class="min-w-0">
          <p class="text-sm font-semibold text-ink truncate group-hover:text-brand"><%= @conversation.property.title %></p>
          <p class="text-xs text-muted"><%= @conversation.property.city %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  document.addEventListener("turbo:load", function() {
    const t = document.getElementById("message-thread");
    if (t) t.scrollTop = t.scrollHeight;
  });
</script>
