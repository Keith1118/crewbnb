<h1>New Message</h1>

<p>Hi <%= @recipient.first_name || @recipient.email.split("@").first %>,</p>

<p><strong><%= @sender.first_name || @sender.email.split("@").first %></strong> sent you a message about <strong><%= @property.title %></strong>:</p>

<div class="detail-box">
  <p style="color: #111c2d; font-size: 14px; margin: 0; white-space: pre-wrap;"><%= @message.body %></p>
</div>

<p style="text-align: center; margin: 24px 0;">
  <a href="<%= conversation_url(@conversation) %>" class="btn">Reply</a>
</p>

<p style="font-size: 12px; color: #9ca3af;">You can reply directly on Crewbnb. All messages are logged for your records.</p>
