<% content_for(:title, "Safety - WorkStays") %>
<% meta_description "How WorkStays keeps guests and hosts safe. Verified properties, secure payments, in-app messaging, and real reviews." %>

<%# ===== HERO ===== %>
<section class="bg-[#001949] pt-10 pb-16">
  <div class="max-w-screen-xl mx-auto px-6">
    <p class="text-blue-200/60 text-sm font-medium mb-2">Safety</p>
    <h1 class="font-headline text-3xl md:text-[2.75rem] font-extrabold text-white leading-[1.1] tracking-tight mb-4 max-w-2xl">
      Your safety matters to us.
    </h1>
    <p class="text-blue-200/80 text-base md:text-lg max-w-lg">
      We take steps to make sure both guests and hosts have a safe experience on WorkStays.
    </p>
  </div>
</section>

<%# ===== SAFETY FOR GUESTS ===== %>
<section class="bg-white py-16">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="max-w-3xl mx-auto">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-10 h-10 rounded-xl bg-[#001949] flex items-center justify-center">
          <span class="material-symbols-outlined text-white text-lg">shield</span>
        </div>
        <h2 class="font-headline text-xl font-bold text-slate-900">For guests</h2>
      </div>

      <div class="space-y-6">
        <div class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-green-600 text-lg mt-0.5 flex-shrink-0">check_circle</span>
          <div>
            <h3 class="font-semibold text-slate-900 mb-1">Verified properties</h3>
            <p class="text-slate-500 text-sm leading-relaxed">All properties are reviewed before they go live. We check the listing details, photos, and host information.</p>
          </div>
        </div>

        <div class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-green-600 text-lg mt-0.5 flex-shrink-0">check_circle</span>
          <div>
            <h3 class="font-semibold text-slate-900 mb-1">Secure payments</h3>
            <p class="text-slate-500 text-sm leading-relaxed">All payments are processed securely. We never share your card details with hosts. Every booking includes a proper invoice.</p>
          </div>
        </div>

        <div class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-green-600 text-lg mt-0.5 flex-shrink-0">check_circle</span>
          <div>
            <h3 class="font-semibold text-slate-900 mb-1">In-app messaging</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Communicate with hosts through WorkStays. All messages are logged so there's a record of any agreements or arrangements.</p>
          </div>
        </div>

        <div class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-green-600 text-lg mt-0.5 flex-shrink-0">check_circle</span>
          <div>
            <h3 class="font-semibold text-slate-900 mb-1">Reviews from real guests</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Only guests who've actually stayed at a property can leave a review. So you're reading real feedback from real workers.</p>
          </div>
        </div>

        <div class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-green-600 text-lg mt-0.5 flex-shrink-0">check_circle</span>
          <div>
            <h3 class="font-semibold text-slate-900 mb-1">Safety amenities listed</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Every listing shows what safety equipment is available — smoke detectors, fire extinguishers, first aid kits, and more.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ===== SAFETY FOR HOSTS ===== %>
<section class="bg-slate-50 py-16 border-t border-slate-100">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="max-w-3xl mx-auto">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-10 h-10 rounded-xl bg-[#001949] flex items-center justify-center">
          <span class="material-symbols-outlined text-white text-lg">home_work</span>
        </div>
        <h2 class="font-headline text-xl font-bold text-slate-900">For hosts</h2>
      </div>

      <div class="space-y-6">
        <div class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-green-600 text-lg mt-0.5 flex-shrink-0">check_circle</span>
          <div>
            <h3 class="font-semibold text-slate-900 mb-1">Verified guests</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Guests must create an account and provide payment details before they can book. You know who's staying at your property.</p>
          </div>
        </div>

        <div class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-green-600 text-lg mt-0.5 flex-shrink-0">check_circle</span>
          <div>
            <h3 class="font-semibold text-slate-900 mb-1">Payment protection</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Guests pay through WorkStays. You don't need to chase payments or handle cash. Everything is recorded and invoiced.</p>
          </div>
        </div>

        <div class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-green-600 text-lg mt-0.5 flex-shrink-0">check_circle</span>
          <div>
            <h3 class="font-semibold text-slate-900 mb-1">Damage reporting</h3>
            <p class="text-slate-500 text-sm leading-relaxed">If something goes wrong, report it through the messaging system within 48 hours. Include photos and we'll help resolve it.</p>
          </div>
        </div>

        <div class="flex gap-4 items-start">
          <span class="material-symbols-outlined text-green-600 text-lg mt-0.5 flex-shrink-0">check_circle</span>
          <div>
            <h3 class="font-semibold text-slate-900 mb-1">You set the rules</h3>
            <p class="text-slate-500 text-sm leading-relaxed">Set your own house rules, cancellation policy, and check-in/checkout times. Guests agree to your terms when they book.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ===== REPORTING ===== %>
<section class="bg-white py-16 border-t border-slate-100">
  <div class="max-w-screen-xl mx-auto px-6 text-center">
    <div class="max-w-lg mx-auto">
      <span class="material-symbols-outlined text-[#001949] text-3xl mb-4">report</span>
      <h2 class="font-headline text-xl font-bold text-slate-900 mb-3">Report a problem</h2>
      <p class="text-slate-500 text-sm mb-6 leading-relaxed">
        If you've experienced a safety issue, or something doesn't look right with a listing or a guest, let us know straight away.
      </p>
      <%= link_to contact_path, class: "inline-flex items-center gap-2 bg-[#001949] text-white px-7 py-3 rounded-xl font-semibold text-sm hover:bg-[#002d75] transition-colors" do %>
        <span class="material-symbols-outlined text-[18px]">mail</span>
        Report an issue
      <% end %>
    </div>
  </div>
</section>
