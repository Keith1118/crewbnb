<% content_for(:title, "Crewbnb — Book crew accommodation in minutes") %>
<% meta_description "Book accommodation for your crew wherever the work is — construction, film, engineering, business teams. Weekday pricing, automatic invoices, stays built for people who travel for work." %>

<%# ===== HERO ===== %>
<section class="bg-[#0F224F] pt-8 pb-14">
  <div class="max-w-screen-xl mx-auto px-6">
    <h1 class="font-headline text-3xl md:text-4xl font-extrabold text-white leading-[1.1] tracking-tight mb-3 max-w-2xl">
      Accommodation for working crews, wherever the job is.
    </h1>
    <p class="text-blue-200/80 text-base md:text-lg max-w-lg mb-8">
      Weekday pricing. Automatic invoices. Stays built for teams who travel for work.
    </p>

    <%# Hero search %>
    <%= form_with url: properties_path, method: :get, class: "bg-white rounded-2xl p-4 shadow-xl max-w-4xl grid grid-cols-2 md:grid-cols-12 gap-3 items-end mb-6" do %>
      <div class="col-span-2 md:col-span-3">
        <%= label_tag :near, "Where's the job?", class: "block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1" %>
        <%= text_field_tag :near, params[:near], placeholder: "Town or county in Ireland",
            class: "w-full px-3 py-3 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:ring-[#0F224F]" %>
      </div>
      <div class="md:col-span-3">
        <%= label_tag :check_in, "Check-in", class: "block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1" %>
        <%= date_field_tag :check_in, params[:check_in], min: Date.current,
            class: "w-full px-3 py-3 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:ring-[#0F224F]" %>
      </div>
      <div class="md:col-span-3">
        <%= label_tag :check_out, "Check-out", class: "block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1" %>
        <%= date_field_tag :check_out, params[:check_out], min: Date.current + 1,
            class: "w-full px-3 py-3 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:ring-[#0F224F]" %>
      </div>
      <div class="md:col-span-1">
        <%= label_tag :guests, "Beds", class: "block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1" %>
        <%= number_field_tag :guests, params[:guests], min: 1, placeholder: "1",
            class: "w-full px-3 py-3 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 text-sm focus:outline-none focus:ring-2 focus:ring-[#0F224F]" %>
      </div>
      <div class="col-span-2 md:col-span-2">
        <%= submit_tag "Search stays", data: { turbo_submits_with: "Searching…" }, class: "w-full bg-[#0F224F] text-white px-4 py-3 rounded-xl font-bold text-sm hover:bg-[#002d75] transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <%= link_to properties_path, class: "inline-flex items-center gap-1 text-blue-200/80 text-sm font-medium hover:text-white transition-colors" do %>
      Or browse all our properties
      <span class="material-symbols-outlined text-base" aria-hidden="true">arrow_forward</span>
    <% end %>

    <%# Stop paying line %>
    <p class="text-white font-semibold text-sm mt-6 mb-4">Stop paying weekend rates for weekday work.</p>

    <%# Built for — immediate self-identification %>
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-6 text-sm text-blue-200/60">
      <span>Built for:</span>
      <span class="text-white font-medium">Construction crews</span>
      <span class="text-blue-300/30">&bull;</span>
      <span class="text-white font-medium">Business teams</span>
      <span class="text-blue-300/30">&bull;</span>
      <span class="text-white font-medium">Engineers &amp; contractors</span>
      <span class="text-blue-300/30">&bull;</span>
      <span class="text-white font-medium">Film &amp; production</span>
      <span class="text-blue-300/30">&bull;</span>
      <span class="text-white font-medium">Any crew on the road</span>
    </div>
  </div>
</section>

<%# ===== SAVINGS BAR ===== %>
<section class="bg-green-50 border-b border-green-100">
  <div class="max-w-screen-xl mx-auto px-6 py-3 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm">
    <div class="flex items-center gap-1.5 text-green-800 font-semibold">
      <span class="material-symbols-outlined text-lg">savings</span>
      Save 15–25% with weekday-only pricing
    </div>
    <span class="hidden md:inline text-green-300">|</span>
    <div class="flex items-center gap-1.5 text-green-800 font-medium">
      <span class="material-symbols-outlined text-lg">receipt_long</span>
      Automatic invoices, no admin
    </div>
    <span class="hidden md:inline text-green-300">|</span>
    <div class="flex items-center gap-1.5 text-green-800 font-medium">
      <span class="material-symbols-outlined text-lg">bolt</span>
      Book in under 2 minutes
    </div>
  </div>
</section>

<%# ===== OUR PROPERTIES ===== %>
<section id="our-properties" class="bg-white py-16 scroll-mt-20">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-headline text-2xl font-bold text-slate-900">Our properties</h2>
      <%= link_to properties_path, class: "inline-flex items-center gap-1 text-sm font-semibold text-[#0F224F] hover:underline" do %>
        View all
        <span class="material-symbols-outlined text-base" aria-hidden="true">arrow_forward</span>
      <% end %>
    </div>

    <% if @properties.present? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @properties.each do |property| %>
          <%= render "properties/property_card", property: property %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-20">
        <span class="material-symbols-outlined text-slate-300 text-5xl mb-4">search_off</span>
        <p class="text-slate-500">No properties listed yet. Check back soon.</p>
      </div>
    <% end %>
  </div>
</section>

<%# ===== HOW IT WORKS ===== %>
<section id="how-it-works" class="bg-slate-50 py-16 border-t border-slate-100 scroll-mt-20">
  <div class="max-w-screen-xl mx-auto px-6">
    <h2 class="font-headline text-2xl font-bold text-slate-900 text-center mb-12">How it works</h2>

    <%# Row 1: steps 1–3 %>
    <div class="grid grid-cols-1 md:grid-cols-5 gap-0 max-w-4xl mx-auto">
      <div class="text-center px-3">
        <div class="w-10 h-10 rounded-full bg-[#0F224F] text-white text-sm font-bold flex items-center justify-center mx-auto mb-3">1</div>
        <p class="font-semibold text-slate-900 text-sm mb-1">Search by project location</p>
        <p class="text-slate-500 text-xs leading-relaxed">Enter where your team is working — not where they're holidaying.</p>
      </div>

      <div class="hidden md:flex items-center justify-center">
        <span class="material-symbols-outlined text-slate-300 text-lg">arrow_forward</span>
      </div>

      <div class="text-center px-3 mt-6 md:mt-0">
        <div class="w-10 h-10 rounded-full bg-[#0F224F] text-white text-sm font-bold flex items-center justify-center mx-auto mb-3">2</div>
        <p class="font-semibold text-slate-900 text-sm mb-1">Set your dates and team size</p>
        <p class="text-slate-500 text-xs leading-relaxed">Mon–Fri stays, number of workers, and requirements (beds, parking, etc.)</p>
      </div>

      <div class="hidden md:flex items-center justify-center">
        <span class="material-symbols-outlined text-slate-300 text-lg">arrow_forward</span>
      </div>

      <div class="text-center px-3 mt-6 md:mt-0">
        <div class="w-10 h-10 rounded-full bg-[#0F224F] text-white text-sm font-bold flex items-center justify-center mx-auto mb-3">3</div>
        <p class="font-semibold text-slate-900 text-sm mb-1">See suitable stays</p>
        <p class="text-slate-500 text-xs leading-relaxed">See stays near your site with a setup that suits you.</p>
      </div>
    </div>

    <%# Row 2: steps 4–6 %>
    <div class="grid grid-cols-1 md:grid-cols-5 gap-0 max-w-4xl mx-auto mt-8 md:mt-10">
      <div class="text-center px-3 mt-6 md:mt-0">
        <div class="w-10 h-10 rounded-full bg-[#0F224F] text-white text-sm font-bold flex items-center justify-center mx-auto mb-3">4</div>
        <p class="font-semibold text-slate-900 text-sm mb-1">Book in minutes</p>
        <p class="text-slate-500 text-xs leading-relaxed">Confirm and pay — no back-and-forth.</p>
      </div>

      <div class="hidden md:flex items-center justify-center">
        <span class="material-symbols-outlined text-slate-300 text-lg">arrow_forward</span>
      </div>

      <div class="text-center px-3 mt-6 md:mt-0">
        <div class="w-10 h-10 rounded-full bg-[#0F224F] text-white text-sm font-bold flex items-center justify-center mx-auto mb-3">5</div>
        <p class="font-semibold text-slate-900 text-sm mb-1">Crew checks in</p>
        <p class="text-slate-500 text-xs leading-relaxed">Keys sorted. Parking sorted. Everything ready.</p>
      </div>

      <div class="hidden md:flex items-center justify-center">
        <span class="material-symbols-outlined text-slate-300 text-lg">arrow_forward</span>
      </div>

      <div class="text-center px-3 mt-6 md:mt-0">
        <div class="w-10 h-10 rounded-full bg-green-600 text-white text-sm font-bold flex items-center justify-center mx-auto mb-3">6</div>
        <p class="font-semibold text-slate-900 text-sm mb-1">Invoice sent automatically</p>
        <p class="text-slate-500 text-xs leading-relaxed">A proper invoice is generated for every booking — no chasing needed.</p>
      </div>
    </div>
  </div>
</section>

<%# ===== COST COMPARISON ===== %>
<section class="bg-white py-16">
  <div class="max-w-screen-xl mx-auto px-6">
    <p class="text-slate-400 text-xs text-center uppercase tracking-wider font-semibold mb-3">Typical 3-person crew, 1 working week</p>
    <h2 class="font-headline text-2xl font-bold text-slate-900 text-center mb-2">You're overpaying. Here's the maths.</h2>
    <p class="text-slate-500 text-center mb-10 text-sm">Wicklow area. Real numbers.</p>

    <div class="max-w-lg mx-auto">
      <div class="grid grid-cols-2 gap-4">
        <div class="bg-slate-50 rounded-2xl p-6 border border-slate-100 text-center">
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Airbnb / Booking.com</p>
          <p class="text-3xl font-bold text-slate-300 line-through">&euro;800</p>
          <div class="mt-3 space-y-1">
            <p class="text-sm text-slate-400">7-night minimum</p>
            <p class="text-sm text-slate-400">No proper invoice</p>
            <p class="text-sm text-slate-400">1–2 beds, no parking</p>
          </div>
        </div>
        <div class="bg-green-50 rounded-2xl p-6 border-2 border-green-200 text-center relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="bg-green-600 text-white text-xs font-bold px-3 py-1 rounded-full">Save &euro;160/week</span>
          </div>
          <p class="text-xs font-semibold text-green-700 uppercase tracking-wider mb-3">Crewbnb</p>
          <p class="text-3xl font-bold text-green-700">&euro;640</p>
          <div class="mt-3 space-y-1">
            <p class="text-sm text-green-700 font-medium">Mon–Fri pricing</p>
            <p class="text-sm text-green-700 font-medium">Automatic invoice</p>
            <p class="text-sm text-green-700 font-medium">4 beds + parking</p>
          </div>
        </div>
      </div>
      <p class="text-center text-xs text-slate-400 mt-4">Based on average Wicklow listings. Your savings will vary.</p>
    </div>
  </div>
</section>

<%# ===== FOR BUSINESSES / FOR HOSTS — outcome-focused ===== %>
<section class="bg-slate-50 py-16 border-t border-slate-100">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

      <%# Businesses %>
      <div class="bg-white rounded-2xl p-8 border border-slate-100">
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-4">Booking for a team?</p>
        <h2 class="font-headline text-xl font-bold text-slate-900 mb-5">Stop booking work trips on Airbnb.</h2>
        <div class="space-y-4">
          <div class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-green-600 text-lg mt-0.5">check_circle</span>
            <p class="text-slate-700 text-sm"><strong>Cut costs 15–25%</strong> — weekday rates, not tourist rates</p>
          </div>
          <div class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-green-600 text-lg mt-0.5">check_circle</span>
            <p class="text-slate-700 text-sm"><strong>Automatic invoices, no admin</strong> — every booking includes a proper invoice</p>
          </div>
          <div class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-green-600 text-lg mt-0.5">check_circle</span>
            <p class="text-slate-700 text-sm"><strong>Beds, parking, laundry</strong> — not hot tubs</p>
          </div>
          <div class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-green-600 text-lg mt-0.5">check_circle</span>
            <p class="text-slate-700 text-sm"><strong>Book in 2 minutes</strong> — no back-and-forth with hosts</p>
          </div>
        </div>
        <div class="mt-6">
          <%= link_to properties_path, class: "inline-flex items-center gap-1.5 bg-[#0F224F] text-white px-5 py-2.5 rounded-xl font-semibold text-sm hover:bg-[#002d75] transition-colors" do %>
            Find a stay now
            <span class="material-symbols-outlined text-base">arrow_forward</span>
          <% end %>
        </div>
      </div>

      <%# Hosts %>
      <div class="bg-white rounded-2xl p-8 border border-slate-100">
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-4">Got a spare property?</p>
        <h2 class="font-headline text-xl font-bold text-slate-900 mb-5">Your place sits empty Mon–Fri. Fix that.</h2>
        <div class="space-y-4">
          <div class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-green-600 text-lg mt-0.5">check_circle</span>
            <p class="text-slate-700 text-sm"><strong>Earn from empty weekdays</strong> — contractors book weeks or months</p>
          </div>
          <div class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-green-600 text-lg mt-0.5">check_circle</span>
            <p class="text-slate-700 text-sm"><strong>No-hassle guests</strong> — they sleep, they work, they leave by 7am</p>
          </div>
          <div class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-green-600 text-lg mt-0.5">check_circle</span>
            <p class="text-slate-700 text-sm"><strong>Repeat bookings</strong> — projects run for weeks, not weekends</p>
          </div>
          <div class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-green-600 text-lg mt-0.5">check_circle</span>
            <p class="text-slate-700 text-sm"><strong>Automatic invoices, no admin</strong> — every booking includes a proper invoice</p>
          </div>
        </div>
        <div class="mt-6">
          <%= link_to new_user_registration_path(role: "host"), class: "inline-flex items-center gap-1.5 border border-slate-900 text-slate-900 px-5 py-2.5 rounded-xl font-semibold text-sm hover:bg-slate-900 hover:text-white transition-colors" do %>
            List your property
            <span class="material-symbols-outlined text-base">arrow_forward</span>
          <% end %>
        </div>
      </div>

    </div>
  </div>
</section>

<%# ===== TRUST — real, not corporate ===== %>
<section class="bg-white py-16 border-t border-slate-100">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-slate-100 rounded-full px-4 py-1.5 text-xs font-semibold text-slate-600 mb-6">
        <span class="material-symbols-outlined text-base">location_on</span>
        Made in Ireland
      </div>
      <p class="text-slate-700 text-lg leading-relaxed mb-4">
        We started this because we <em>are</em> the hosts.
      </p>
      <p class="text-slate-500 text-sm leading-relaxed max-w-lg mx-auto">
        We've housed working crews ourselves and dealt with every problem — teams who need invoices, accountants who need receipts, people who just need a comfortable bed near the job and somewhere to park. Whether it's a construction crew, a film unit or a business team, we built Crewbnb because nothing else was built for this.
      </p>
    </div>
  </div>
</section>

<%# ===== FINAL CTA ===== %>
<section class="bg-slate-50 py-16 border-t border-slate-100">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="bg-[#0F224F] rounded-2xl px-8 py-14 md:px-16 text-center relative overflow-hidden">
      <h2 class="font-headline text-2xl md:text-3xl font-bold text-white mb-3">
        Your crew needs somewhere to stay.<br>Book it now.
      </h2>
      <p class="text-blue-200/60 max-w-md mx-auto mb-8 text-sm">
        Takes 2 minutes to book. Every booking includes a proper invoice — no admin.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <%= link_to properties_path, class: "bg-white text-[#0F224F] px-7 py-3 rounded-xl font-semibold text-sm hover:bg-blue-50 transition-colors" do %>
          Find a stay
        <% end %>
        <%= link_to new_user_registration_path(role: "host"), class: "border border-white/25 text-white px-7 py-3 rounded-xl font-semibold text-sm hover:bg-white/10 transition-colors" do %>
          List your property
        <% end %>
      </div>
    </div>
  </div>
</section>
