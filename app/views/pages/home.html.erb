<% content_for(:title, "WorkStays — Book crew accommodation in minutes") %>
<% meta_description "Book accommodation for your crew near job sites. Weekday pricing, automatic invoices, and stays built for workers. Save 30-40% vs Airbnb." %>

<%# ===== HERO ===== %>
<section class="bg-[#001949] pt-8 pb-14">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="flex flex-wrap items-center gap-2 mb-6">
      <span class="bg-green-500/20 text-green-300 text-xs font-semibold px-3 py-1 rounded-full">Properties available this week</span>
    </div>

    <h1 class="font-headline text-3xl md:text-[2.75rem] font-extrabold text-white leading-[1.1] tracking-tight mb-3 max-w-2xl">
      Book crew accommodation near your job site.
    </h1>
    <p class="text-blue-200/80 text-base md:text-lg max-w-lg mb-8">
      Weekday pricing. Automatic invoices. Stays ideal for workers.
    </p>

    <%# Search box %>
    <%= form_tag properties_path, method: :get, class: "bg-white rounded-2xl shadow-xl max-w-3xl" do %>
      <div class="grid grid-cols-1 md:grid-cols-5 items-end">
        <div class="px-4 py-3.5 md:border-r border-slate-100">
          <label class="block text-[10px] font-semibold text-slate-400 uppercase tracking-wider mb-1">Project Location</label>
          <%= text_field_tag :location, params[:location], placeholder: "e.g. where your team is working",
              class: "w-full bg-transparent border-none p-0 focus:ring-0 text-slate-900 text-sm font-medium placeholder:text-slate-300" %>
        </div>
        <div class="px-4 py-3.5 md:border-r border-slate-100">
          <label class="block text-[10px] font-semibold text-slate-400 uppercase tracking-wider mb-1">Check in</label>
          <%= date_field_tag :check_in, params[:check_in],
              class: "w-full bg-transparent border-none p-0 focus:ring-0 text-slate-900 text-sm font-medium" %>
        </div>
        <div class="px-4 py-3.5 md:border-r border-slate-100">
          <label class="block text-[10px] font-semibold text-slate-400 uppercase tracking-wider mb-1">Check out</label>
          <%= date_field_tag :check_out, params[:check_out],
              class: "w-full bg-transparent border-none p-0 focus:ring-0 text-slate-900 text-sm font-medium" %>
        </div>
        <div class="px-4 py-3.5 md:border-r border-slate-100">
          <label class="block text-[10px] font-semibold text-slate-400 uppercase tracking-wider mb-1">Team size</label>
          <%= number_field_tag :guests, params[:guests], min: 1, placeholder: "Guests",
              class: "w-full bg-transparent border-none p-0 focus:ring-0 text-slate-900 text-sm font-medium placeholder:text-slate-300" %>
        </div>
        <div class="p-2">
          <button type="submit" class="w-full h-11 bg-[#001949] text-white rounded-xl font-semibold text-sm flex items-center justify-center gap-1.5 hover:bg-[#002d75] transition-colors cursor-pointer">
            <span class="material-symbols-outlined text-[18px]">search</span>
            Find stays
          </button>
        </div>
      </div>
    <% end %>
    <p class="text-blue-200/40 text-xs mt-3">Takes 2 minutes to book</p>

    <%# Stop paying line %>
    <p class="text-white font-semibold text-sm mt-6 mb-4">Stop paying weekend rates for weekday work.</p>

    <%# Built for — immediate self-identification %>
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mt-6 text-sm text-blue-200/60">
      <span>Built for:</span>
      <span class="text-white font-medium">Construction companies</span>
      <span class="text-blue-300/30">&bull;</span>
      <span class="text-white font-medium">Contractors</span>
      <span class="text-blue-300/30">&bull;</span>
      <span class="text-white font-medium">Fit-out teams</span>
      <span class="text-blue-300/30">&bull;</span>
      <span class="text-white font-medium">Engineers on site</span>
    </div>
  </div>
</section>

<%# ===== SAVINGS BAR ===== %>
<section class="bg-green-50 border-b border-green-100">
  <div class="max-w-screen-xl mx-auto px-6 py-3 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm">
    <div class="flex items-center gap-1.5 text-green-800 font-semibold">
      <span class="material-symbols-outlined text-[18px]">savings</span>
      Save 30–40% with weekday-only pricing
    </div>
    <span class="hidden md:inline text-green-300">|</span>
    <div class="flex items-center gap-1.5 text-green-800 font-medium">
      <span class="material-symbols-outlined text-[18px]">receipt_long</span>
      Automatic invoices, no admin
    </div>
    <span class="hidden md:inline text-green-300">|</span>
    <div class="flex items-center gap-1.5 text-green-800 font-medium">
      <span class="material-symbols-outlined text-[18px]">bolt</span>
      Book in under 2 minutes
    </div>
  </div>
</section>

<%# ===== QUICK FILTERS ===== %>
<section class="bg-white border-b border-slate-100 sticky top-[65px] z-40">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="flex items-center gap-8 overflow-x-auto py-4 text-sm no-scrollbar">
      <%= link_to properties_path, class: "flex flex-col items-center gap-1 text-slate-900 font-medium border-b-2 border-slate-900 pb-2 px-1 flex-shrink-0" do %>
        <span class="material-symbols-outlined text-[22px]">apartment</span>
        <span>All stays</span>
      <% end %>
      <%= link_to properties_path(property_type: "House"), class: "flex flex-col items-center gap-1 text-slate-400 hover:text-slate-700 pb-2 px-1 flex-shrink-0 transition-colors" do %>
        <span class="material-symbols-outlined text-[22px]">house</span>
        <span>Houses</span>
      <% end %>
      <%= link_to properties_path(property_type: "Apartment"), class: "flex flex-col items-center gap-1 text-slate-400 hover:text-slate-700 pb-2 px-1 flex-shrink-0 transition-colors" do %>
        <span class="material-symbols-outlined text-[22px]">location_city</span>
        <span>Apartments</span>
      <% end %>
      <%= link_to properties_path(guests: 3), class: "flex flex-col items-center gap-1 text-slate-400 hover:text-slate-700 pb-2 px-1 flex-shrink-0 transition-colors" do %>
        <span class="material-symbols-outlined text-[22px]">bed</span>
        <span>3+ beds</span>
      <% end %>
      <%= link_to properties_path(has_parking: true), class: "flex flex-col items-center gap-1 text-slate-400 hover:text-slate-700 pb-2 px-1 flex-shrink-0 transition-colors" do %>
        <span class="material-symbols-outlined text-[22px]">local_parking</span>
        <span>Parking</span>
      <% end %>
    </div>
  </div>
</section>

<%# ===== PROPERTY CAROUSEL ===== %>
<section class="bg-white py-10" data-controller="carousel">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="font-headline text-lg font-bold text-slate-900">Available this week</h2>
        <p class="text-xs text-amber-600 font-medium mt-0.5">Limited weekday availability</p>
      </div>
      <div class="flex items-center gap-3">
        <button data-action="click->carousel#prev" class="w-8 h-8 rounded-full border border-slate-200 flex items-center justify-center hover:bg-slate-50 transition-colors cursor-pointer">
          <span class="material-symbols-outlined text-slate-600 text-[18px]">arrow_back</span>
        </button>
        <span class="text-xs text-slate-400 font-medium" data-carousel-target="counter"></span>
        <button data-action="click->carousel#next" class="w-8 h-8 rounded-full border border-slate-200 flex items-center justify-center hover:bg-slate-50 transition-colors cursor-pointer">
          <span class="material-symbols-outlined text-slate-600 text-[18px]">arrow_forward</span>
        </button>
      </div>
    </div>

    <% if @properties.present? %>
      <div class="relative overflow-hidden">
        <% @properties.in_groups_of(3, false).each_with_index do |group, i| %>
          <div class="carousel-page <%= i == 0 ? '' : 'hidden' %>" data-carousel-target="page">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10">
              <% group.each do |property| %>
                <%= render "properties/property_card", property: property %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <div class="text-center mt-10">
        <%= link_to properties_path, class: "inline-flex items-center gap-2 border border-slate-900 text-slate-900 px-6 py-3 rounded-xl font-semibold text-sm hover:bg-slate-900 hover:text-white transition-colors" do %>
          Show all properties
          <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-20">
        <span class="material-symbols-outlined text-slate-300 text-[48px] mb-4">search_off</span>
        <p class="text-slate-500">No properties listed yet. Check back soon.</p>
      </div>
    <% end %>
  </div>
</section>

<%# ===== HOW IT WORKS ===== %>
<section id="how-it-works" class="bg-slate-50 py-16 border-t border-slate-100 scroll-mt-20">
  <div class="max-w-screen-xl mx-auto px-6">
    <h2 class="font-headline text-2xl font-bold text-slate-900 text-center mb-12">How it works</h2>

    <%# Row 1: steps 1–3 %>
    <div class="grid grid-cols-1 md:grid-cols-5 gap-0 max-w-4xl mx-auto">
      <div class="text-center px-3">
        <div class="w-10 h-10 rounded-full bg-[#001949] text-white text-sm font-bold flex items-center justify-center mx-auto mb-3">1</div>
        <p class="font-semibold text-slate-900 text-sm mb-1">Search by project location</p>
        <p class="text-slate-500 text-xs leading-relaxed">Enter where your team is working — not where they're holidaying.</p>
      </div>

      <div class="hidden md:flex items-center justify-center">
        <span class="material-symbols-outlined text-slate-300 text-lg">arrow_forward</span>
      </div>

      <div class="text-center px-3 mt-6 md:mt-0">
        <div class="w-10 h-10 rounded-full bg-[#001949] text-white text-sm font-bold flex items-center justify-center mx-auto mb-3">2</div>
        <p class="font-semibold text-slate-900 text-sm mb-1">Set your dates and team size</p>
        <p class="text-slate-500 text-xs leading-relaxed">Mon–Fri stays, number of workers, and requirements (beds, parking, etc.)</p>
      </div>

      <div class="hidden md:flex items-center justify-center">
        <span class="material-symbols-outlined text-slate-300 text-lg">arrow_forward</span>
      </div>

      <div class="text-center px-3 mt-6 md:mt-0">
        <div class="w-10 h-10 rounded-full bg-[#001949] text-white text-sm font-bold flex items-center justify-center mx-auto mb-3">3</div>
        <p class="font-semibold text-slate-900 text-sm mb-1">See suitable stays</p>
        <p class="text-slate-500 text-xs leading-relaxed">See stays near your site with a setup that suits you.</p>
      </div>
    </div>

    <%# Row 2: steps 4–6 %>
    <div class="grid grid-cols-1 md:grid-cols-5 gap-0 max-w-4xl mx-auto mt-8 md:mt-10">
      <div class="text-center px-3 mt-6 md:mt-0">
        <div class="w-10 h-10 rounded-full bg-[#001949] text-white text-sm font-bold flex items-center justify-center mx-auto mb-3">4</div>
        <p class="font-semibold text-slate-900 text-sm mb-1">Book in minutes</p>
        <p class="text-slate-500 text-xs leading-relaxed">Confirm and pay — no back-and-forth.</p>
      </div>

      <div class="hidden md:flex items-center justify-center">
        <span class="material-symbols-outlined text-slate-300 text-lg">arrow_forward</span>
      </div>

      <div class="text-center px-3 mt-6 md:mt-0">
        <div class="w-10 h-10 rounded-full bg-[#001949] text-white text-sm font-bold flex items-center justify-center mx-auto mb-3">5</div>
        <p class="font-semibold text-slate-900 text-sm mb-1">Crew checks in</p>
        <p class="text-slate-500 text-xs leading-relaxed">Keys sorted. Parking sorted. Everything ready.</p>
      </div>

      <div class="hidden md:flex items-center justify-center">
        <span class="material-symbols-outlined text-slate-300 text-lg">arrow_forward</span>
      </div>

      <div class="text-center px-3 mt-6 md:mt-0">
        <div class="w-10 h-10 rounded-full bg-green-600 text-white text-sm font-bold flex items-center justify-center mx-auto mb-3">6</div>
        <p class="font-semibold text-slate-900 text-sm mb-1">Invoice sent automatically</p>
        <p class="text-slate-500 text-xs leading-relaxed">A proper invoice is generated for every booking — no chasing needed.</p>
      </div>
    </div>
  </div>
</section>

<%# ===== COST COMPARISON ===== %>
<section class="bg-white py-16">
  <div class="max-w-screen-xl mx-auto px-6">
    <p class="text-slate-400 text-xs text-center uppercase tracking-wider font-semibold mb-3">Typical 3-person crew, 1 working week</p>
    <h2 class="font-headline text-2xl font-bold text-slate-900 text-center mb-2">You're overpaying. Here's the maths.</h2>
    <p class="text-slate-500 text-center mb-10 text-sm">Wicklow area. Real numbers.</p>

    <div class="max-w-lg mx-auto">
      <div class="grid grid-cols-2 gap-4">
        <div class="bg-slate-50 rounded-2xl p-6 border border-slate-100 text-center">
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Airbnb / Booking.com</p>
          <p class="text-3xl font-bold text-slate-300 line-through">&euro;1,050</p>
          <div class="mt-3 space-y-1">
            <p class="text-sm text-slate-400">7-night minimum</p>
            <p class="text-sm text-slate-400">No proper invoice</p>
            <p class="text-sm text-slate-400">1–2 beds, no parking</p>
          </div>
        </div>
        <div class="bg-green-50 rounded-2xl p-6 border-2 border-green-200 text-center relative">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span class="bg-green-600 text-white text-xs font-bold px-3 py-1 rounded-full">Save &euro;410/week</span>
          </div>
          <p class="text-xs font-semibold text-green-700 uppercase tracking-wider mb-3">WorkStays</p>
          <p class="text-3xl font-bold text-green-700">&euro;640</p>
          <div class="mt-3 space-y-1">
            <p class="text-sm text-green-700 font-medium">Mon–Fri pricing</p>
            <p class="text-sm text-green-700 font-medium">Automatic invoice</p>
            <p class="text-sm text-green-700 font-medium">4 beds + parking</p>
          </div>
        </div>
      </div>
      <p class="text-center text-xs text-slate-400 mt-4">Based on average Wicklow listings. Your savings will vary.</p>
    </div>
  </div>
</section>

<%# ===== FOR BUSINESSES / FOR HOSTS — outcome-focused ===== %>
<section class="bg-slate-50 py-16 border-t border-slate-100">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

      <%# Businesses %>
      <div class="bg-white rounded-2xl p-8 border border-slate-100">
        <p class="text-[11px] font-semibold text-slate-400 uppercase tracking-wider mb-4">Booking for a team?</p>
        <h2 class="font-headline text-xl font-bold text-slate-900 mb-5">Stop booking work trips on Airbnb.</h2>
        <div class="space-y-4">
          <div class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-green-600 text-lg mt-0.5">check_circle</span>
            <p class="text-slate-700 text-sm"><strong>Cut costs 30–40%</strong> — weekday rates, not tourist rates</p>
          </div>
          <div class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-green-600 text-lg mt-0.5">check_circle</span>
            <p class="text-slate-700 text-sm"><strong>Automatic invoices, no admin</strong> — every booking includes a proper invoice</p>
          </div>
          <div class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-green-600 text-lg mt-0.5">check_circle</span>
            <p class="text-slate-700 text-sm"><strong>Beds, parking, laundry</strong> — not hot tubs</p>
          </div>
          <div class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-green-600 text-lg mt-0.5">check_circle</span>
            <p class="text-slate-700 text-sm"><strong>Book in 2 minutes</strong> — no back-and-forth with hosts</p>
          </div>
        </div>
        <div class="mt-6">
          <%= link_to properties_path, class: "inline-flex items-center gap-1.5 bg-[#001949] text-white px-5 py-2.5 rounded-xl font-semibold text-sm hover:bg-[#002d75] transition-colors" do %>
            Find a stay now
            <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
          <% end %>
        </div>
      </div>

      <%# Hosts %>
      <div class="bg-white rounded-2xl p-8 border border-slate-100">
        <p class="text-[11px] font-semibold text-slate-400 uppercase tracking-wider mb-4">Got a spare property?</p>
        <h2 class="font-headline text-xl font-bold text-slate-900 mb-5">Your place sits empty Mon–Fri. Fix that.</h2>
        <div class="space-y-4">
          <div class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-green-600 text-lg mt-0.5">check_circle</span>
            <p class="text-slate-700 text-sm"><strong>Earn from empty weekdays</strong> — contractors book weeks or months</p>
          </div>
          <div class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-green-600 text-lg mt-0.5">check_circle</span>
            <p class="text-slate-700 text-sm"><strong>No-hassle guests</strong> — they sleep, they work, they leave by 7am</p>
          </div>
          <div class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-green-600 text-lg mt-0.5">check_circle</span>
            <p class="text-slate-700 text-sm"><strong>Repeat bookings</strong> — projects run for weeks, not weekends</p>
          </div>
          <div class="flex gap-3 items-start">
            <span class="material-symbols-outlined text-green-600 text-lg mt-0.5">check_circle</span>
            <p class="text-slate-700 text-sm"><strong>Automatic invoices, no admin</strong> — every booking includes a proper invoice</p>
          </div>
        </div>
        <div class="mt-6">
          <%= link_to new_user_registration_path(role: "host"), class: "inline-flex items-center gap-1.5 border border-slate-900 text-slate-900 px-5 py-2.5 rounded-xl font-semibold text-sm hover:bg-slate-900 hover:text-white transition-colors" do %>
            List your property
            <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
          <% end %>
        </div>
      </div>

    </div>
  </div>
</section>

<%# ===== TRUST — real, not corporate ===== %>
<section class="bg-white py-14 border-t border-slate-100">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-slate-100 rounded-full px-4 py-1.5 text-xs font-semibold text-slate-600 mb-6">
        <span class="material-symbols-outlined text-[16px]">location_on</span>
        Made in Tulfarris, Wicklow
      </div>
      <p class="text-slate-700 text-lg leading-relaxed mb-4">
        We started this because we <em>are</em> the hosts.
      </p>
      <p class="text-slate-500 text-sm leading-relaxed max-w-lg mx-auto">
        We've housed contractors ourselves and dealt with every problem — guests who need invoices, accountants who need receipts, workers who just need a bed near site and somewhere to park the van. We built WorkStays because nothing else was built for this.
      </p>
    </div>
  </div>
</section>

<%# ===== FINAL CTA ===== %>
<section class="bg-slate-50 py-16 border-t border-slate-100">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="bg-[#001949] rounded-2xl px-8 py-14 md:px-16 text-center relative overflow-hidden">
      <%# Urgency badge %>
      <div class="flex justify-center mb-6">
        <span class="bg-green-500/20 text-green-300 text-xs font-semibold px-3 py-1 rounded-full">Limited weekday availability — book early</span>
      </div>

      <h2 class="font-headline text-2xl md:text-3xl font-bold text-white mb-3">
        Your crew needs somewhere to stay.<br>Book it now.
      </h2>
      <p class="text-blue-200/60 max-w-md mx-auto mb-8 text-sm">
        Takes 2 minutes to book. Every booking includes a proper invoice — no admin.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <%= link_to properties_path, class: "bg-white text-[#001949] px-7 py-3 rounded-xl font-semibold text-sm hover:bg-blue-50 transition-colors" do %>
          Find a stay
        <% end %>
        <%= link_to new_user_registration_path(role: "host"), class: "border border-white/25 text-white px-7 py-3 rounded-xl font-semibold text-sm hover:bg-white/10 transition-colors" do %>
          List your property
        <% end %>
      </div>
    </div>
  </div>
</section>
