<% content_for(:page_title, "Bookings") %>

<%# Header %>
<div class="flex items-center justify-between mb-8">
  <div>
    <h2 class="font-headline text-2xl font-extrabold text-on-surface tracking-tight">All Bookings</h2>
    <p class="text-on-surface-variant mt-1">View and manage all platform bookings.</p>
  </div>
</div>

<%# Bookings Table %>
<div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/15 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-outline-variant/15 text-left">
          <th class="px-6 py-4 text-xs font-medium text-on-surface-variant uppercase tracking-widest">Ref</th>
          <th class="px-6 py-4 text-xs font-medium text-on-surface-variant uppercase tracking-widest">Guest</th>
          <th class="px-6 py-4 text-xs font-medium text-on-surface-variant uppercase tracking-widest">Property</th>
          <th class="px-6 py-4 text-xs font-medium text-on-surface-variant uppercase tracking-widest">Dates</th>
          <th class="px-6 py-4 text-xs font-medium text-on-surface-variant uppercase tracking-widest">Total</th>
          <th class="px-6 py-4 text-xs font-medium text-on-surface-variant uppercase tracking-widest">Status</th>
          <th class="px-6 py-4 text-xs font-medium text-on-surface-variant uppercase tracking-widest">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-outline-variant/10">
        <% @bookings.each do |booking| %>
          <tr class="hover:bg-surface-container/30 transition-colors">
            <td class="px-6 py-4">
              <span class="font-mono text-xs font-medium text-on-surface"><%= booking.invoice_reference %></span>
            </td>
            <td class="px-6 py-4">
              <div class="flex items-center gap-2">
                <% if booking.user.avatar.attached? %>
                  <%= image_tag booking.user.avatar, class: "w-7 h-7 rounded-full object-cover" %>
                <% else %>
                  <div class="w-7 h-7 rounded-full bg-primary-container flex items-center justify-center">
                    <span class="text-on-primary-container text-[10px] font-bold"><%= booking.user.email[0].upcase %></span>
                  </div>
                <% end %>
                <span class="text-on-surface-variant">
                  <%= booking.user.first_name.present? ? "#{booking.user.first_name} #{booking.user.last_name}" : booking.user.email %>
                </span>
              </div>
            </td>
            <td class="px-6 py-4 text-on-surface-variant"><%= truncate(booking.property.title, length: 25) %></td>
            <td class="px-6 py-4 text-on-surface-variant whitespace-nowrap">
              <%= booking.check_in.strftime("%b %d") %> &mdash; <%= booking.check_out.strftime("%b %d") %>
            </td>
            <td class="px-6 py-4 font-medium text-on-surface whitespace-nowrap">&euro;<%= number_with_delimiter(booking.total_price) %></td>
            <td class="px-6 py-4">
              <% badge_classes = case booking.status
                 when "pending" then "bg-yellow-100 text-yellow-800"
                 when "confirmed" then "bg-green-100 text-green-800"
                 when "cancelled" then "bg-red-100 text-red-800"
                 when "completed" then "bg-blue-100 text-blue-800"
                 end %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold <%= badge_classes %>">
                <%= booking.status.capitalize %>
              </span>
            </td>
            <td class="px-6 py-4">
              <%= link_to "View", admin_booking_path(booking), class: "text-primary-container hover:underline font-medium text-xs" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%# Pagination %>
<div class="mt-8 flex justify-center">
  <%== pagy_nav(@pagy) %>
</div>
