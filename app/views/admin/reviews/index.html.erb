<% content_for(:page_title, "Reviews") %>

<%# Header %>
<div class="flex items-center justify-between mb-8">
  <div>
    <h2 class="font-headline text-2xl font-extrabold text-on-surface tracking-tight">Reviews</h2>
    <p class="text-on-surface-variant mt-1">Moderate user reviews across the platform.</p>
  </div>
</div>

<%# Reviews Table %>
<% if @reviews.any? %>
  <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/15 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-outline-variant/15 text-left">
            <th class="px-6 py-4 text-xs font-medium text-on-surface-variant uppercase tracking-widest">Reviewer</th>
            <th class="px-6 py-4 text-xs font-medium text-on-surface-variant uppercase tracking-widest">Property</th>
            <th class="px-6 py-4 text-xs font-medium text-on-surface-variant uppercase tracking-widest">Rating</th>
            <th class="px-6 py-4 text-xs font-medium text-on-surface-variant uppercase tracking-widest">Comment</th>
            <th class="px-6 py-4 text-xs font-medium text-on-surface-variant uppercase tracking-widest">Date</th>
            <th class="px-6 py-4 text-xs font-medium text-on-surface-variant uppercase tracking-widest">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant/10">
          <% @reviews.each do |review| %>
            <tr class="hover:bg-surface-container/30 transition-colors">
              <td class="px-6 py-4">
                <div class="flex items-center gap-2">
                  <% if review.reviewer.avatar.attached? %>
                    <%= image_tag review.reviewer.avatar, class: "w-7 h-7 rounded-full object-cover" %>
                  <% else %>
                    <div class="w-7 h-7 rounded-full bg-primary-container flex items-center justify-center">
                      <span class="text-on-primary-container text-[10px] font-bold"><%= review.reviewer.email[0].upcase %></span>
                    </div>
                  <% end %>
                  <span class="text-on-surface font-medium">
                    <%= review.reviewer.first_name.present? ? "#{review.reviewer.first_name} #{review.reviewer.last_name}" : review.reviewer.email %>
                  </span>
                </div>
              </td>
              <td class="px-6 py-4 text-on-surface-variant">
                <% if review.reviewable.present? %>
                  <%= truncate(review.reviewable.title, length: 25) %>
                <% else %>
                  <span class="italic">Deleted</span>
                <% end %>
              </td>
              <td class="px-6 py-4">
                <div class="flex items-center gap-0.5">
                  <% (1..5).each do |star| %>
                    <span class="material-symbols-outlined text-sm <%= star <= review.rating ? 'text-yellow-500' : 'text-on-surface-variant/20' %>"
                          style="font-variation-settings: 'FILL' 1;">
                      star
                    </span>
                  <% end %>
                </div>
              </td>
              <td class="px-6 py-4 text-on-surface-variant max-w-xs">
                <p class="truncate"><%= review.comment %></p>
              </td>
              <td class="px-6 py-4 text-on-surface-variant whitespace-nowrap"><%= review.created_at.strftime("%b %d, %Y") %></td>
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <% if review.reviewable.present? %>
                    <%= link_to "Property", admin_property_path(review.reviewable), class: "text-primary-container hover:underline font-medium text-xs" %>
                  <% end %>
                  <%= button_to admin_review_path(review), method: :delete,
                      class: "inline-flex items-center gap-1 text-red-600 hover:text-red-800 font-medium text-xs",
                      data: { turbo_confirm: "Are you sure you want to delete this review?" } do %>
                    <span class="material-symbols-outlined text-sm">delete</span>
                    Delete
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <%# Pagination %>
  <div class="mt-8 flex justify-center">
    <%== pagy_nav(@pagy) %>
  </div>
<% else %>
  <div class="text-center py-20 bg-surface-container-lowest rounded-2xl border border-outline-variant/15">
    <span class="material-symbols-outlined text-6xl text-on-surface-variant/30 mb-4">reviews</span>
    <h3 class="font-headline text-xl font-bold text-on-surface mb-2">No reviews yet</h3>
    <p class="text-on-surface-variant">Reviews from guests will appear here.</p>
  </div>
<% end %>
