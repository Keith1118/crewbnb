<% content_for(:page_title, "Contact Submission") %>

<div class="max-w-3xl">
  <%# Back %>
  <div class="mb-6">
    <%= link_to admin_contact_submissions_path, class: "inline-flex items-center gap-2 text-sm text-on-surface-variant hover:text-on-surface transition-colors" do %>
      <span class="material-symbols-outlined text-base">arrow_back</span>
      Back to all submissions
    <% end %>
  </div>

  <%# Header %>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="font-headline text-2xl font-extrabold text-on-surface tracking-tight"><%= @contact_submission.subject %></h2>
      <p class="text-on-surface-variant mt-1">From <%= @contact_submission.name %> &middot; <%= @contact_submission.created_at.strftime("%b %d, %Y at %H:%M") %></p>
    </div>
    <% if @contact_submission.pending? %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-yellow-100 text-yellow-800 border border-yellow-200">New</span>
    <% elsif @contact_submission.read? %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-blue-100 text-blue-800 border border-blue-200">Read</span>
    <% else %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800 border border-green-200">Replied</span>
    <% end %>
  </div>

  <%# Details %>
  <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/15 p-6 space-y-5">
    <div class="grid grid-cols-2 gap-6">
      <div>
        <p class="text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-1">Name</p>
        <p class="font-medium text-on-surface"><%= @contact_submission.name %></p>
      </div>
      <div>
        <p class="text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-1">Email</p>
        <p class="font-medium text-on-surface">
          <a href="mailto:<%= @contact_submission.email %>" class="text-primary-container hover:underline"><%= @contact_submission.email %></a>
        </p>
      </div>
    </div>

    <div>
      <p class="text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-1">Subject</p>
      <p class="font-medium text-on-surface"><%= @contact_submission.subject %></p>
    </div>

    <div class="border-t border-outline-variant/15 pt-5">
      <p class="text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-2">Message</p>
      <div class="bg-slate-50 rounded-xl p-5 text-on-surface text-sm leading-relaxed whitespace-pre-wrap"><%= @contact_submission.message %></div>
    </div>
  </div>

  <%# Actions %>
  <div class="mt-6 flex items-center gap-3">
    <a href="mailto:<%= @contact_submission.email %>?subject=Re: <%= @contact_submission.subject %>"
       class="inline-flex items-center gap-2 bg-[#001949] text-white px-5 py-2.5 rounded-xl font-semibold text-sm hover:bg-[#002d75] transition-colors">
      <span class="material-symbols-outlined text-lg">reply</span>
      Reply via email
    </a>
    <%= button_to admin_contact_submission_path(@contact_submission), method: :delete,
        class: "inline-flex items-center gap-2 border border-red-200 text-red-600 px-5 py-2.5 rounded-xl font-semibold text-sm hover:bg-red-50 transition-colors",
        data: { turbo_confirm: "Delete this submission?" } do %>
      <span class="material-symbols-outlined text-lg">delete</span>
      Delete
    <% end %>
  </div>
</div>
