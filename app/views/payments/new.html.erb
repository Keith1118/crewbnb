<% content_for(:title, "Complete Payment - Crewbase") %>

<% content_for(:head) do %>
  <script src="https://js.stripe.com/v3/"></script>
<% end %>

<section class="max-w-screen-md mx-auto px-6 py-12">
  <div class="flex items-center gap-3 mb-8">
    <%= link_to booking_path(@booking), class: "text-on-surface-variant hover:text-on-surface transition-colors" do %>
      <span class="material-symbols-outlined text-xl">arrow_back</span>
    <% end %>
    <h1 class="font-headline text-2xl font-extrabold text-on-surface tracking-tight">Complete Payment</h1>
  </div>

  <div class="space-y-6">
    <%# Booking Summary %>
    <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/15 p-6">
      <h2 class="font-headline font-bold text-on-surface mb-4">Booking Summary</h2>

      <div class="space-y-3">
        <div class="flex items-start justify-between">
          <div>
            <p class="font-headline font-bold text-on-surface"><%= @booking.property.title %></p>
            <p class="text-sm text-on-surface-variant flex items-center gap-1 mt-1">
              <span class="material-symbols-outlined text-base">location_on</span>
              <%= @booking.property.city %>, <%= @booking.property.country %>
            </p>
          </div>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold border bg-yellow-100 text-yellow-800 border-yellow-200">
            Pending Payment
          </span>
        </div>

        <div class="border-t border-outline-variant/15 pt-3 grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
          <div>
            <p class="text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-1">Check-in</p>
            <p class="font-medium text-on-surface"><%= @booking.check_in.strftime("%b %d, %Y") %></p>
          </div>
          <div>
            <p class="text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-1">Check-out</p>
            <p class="font-medium text-on-surface"><%= @booking.check_out.strftime("%b %d, %Y") %></p>
          </div>
          <div>
            <p class="text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-1">Nights</p>
            <p class="font-medium text-on-surface"><%= @booking.nights %></p>
          </div>
          <div>
            <p class="text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-1">Guests</p>
            <p class="font-medium text-on-surface"><%= @booking.guests_count %></p>
          </div>
        </div>

        <div class="border-t border-outline-variant/15 pt-3">
          <p class="text-xs font-medium text-on-surface-variant uppercase tracking-widest mb-1">Invoice Reference</p>
          <p class="font-mono font-medium text-on-surface"><%= @booking.invoice_reference %></p>
        </div>
      </div>
    </div>

    <%# Price Breakdown %>
    <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/15 p-6">
      <h2 class="font-headline font-bold text-on-surface mb-4">Price Breakdown</h2>
      <div class="space-y-2 text-sm">
        <div class="flex justify-between">
          <span class="text-on-surface-variant">&euro;<%= number_with_delimiter(@booking.property.price_per_night, delimiter: ",") %> x <%= @booking.nights %> nights</span>
          <span class="text-on-surface font-medium">&euro;<%= number_with_delimiter(@booking.total_price, delimiter: ",") %></span>
        </div>
        <div class="flex justify-between">
          <span class="text-on-surface-variant">Service fee</span>
          <span class="text-green-600 font-medium">&euro;0.00</span>
        </div>
        <div class="border-t border-outline-variant/15 pt-2 mt-2">
          <div class="flex justify-between">
            <span class="font-headline font-bold text-on-surface">Total</span>
            <span class="font-headline font-bold text-on-surface text-lg">&euro;<%= number_with_delimiter(@booking.total_price, delimiter: ",") %></span>
          </div>
          <p class="text-xs text-on-surface-variant mt-1">EUR &middot; Invoice will be generated automatically</p>
        </div>
      </div>
    </div>

    <%# Payment Form %>
    <div class="bg-surface-container-lowest rounded-2xl border border-outline-variant/15 p-6"
         data-controller="payment-form"
         data-payment-form-client-secret-value="<%= @client_secret %>"
         data-payment-form-publishable-key-value="<%= @stripe_publishable_key %>"
         data-payment-form-return-url-value="<%= complete_booking_payment_url(@booking) %>">
      <h2 class="font-headline font-bold text-on-surface mb-6">Payment Details</h2>

      <form id="payment-form" class="space-y-5" data-action="submit->payment-form#submit">
        <%# Stripe Payment Element %>
        <div id="payment-element" class="min-h-[200px]"></div>

        <%# Error Messages %>
        <div id="payment-errors" class="text-sm text-red-600 font-medium" role="alert"></div>

        <%# Security Badge %>
        <div class="bg-green-50 rounded-xl p-4 flex items-center gap-3 border border-green-100">
          <span class="material-symbols-outlined text-green-600 text-xl">verified_user</span>
          <div>
            <p class="text-sm font-medium text-green-800">Secure payment</p>
            <p class="text-xs text-green-600">Your payment details are encrypted and processed securely by Stripe. We never store your card details.</p>
          </div>
        </div>

        <%# Submit Button %>
        <div class="pt-2">
          <button type="submit" data-payment-form-target="submitButton"
                  class="w-full bg-[#0F224F] text-white px-8 py-4 rounded-xl font-headline font-bold text-lg hover:bg-[#002d75] active:scale-[0.98] transition-all cursor-pointer flex items-center justify-center gap-2">
            <span data-payment-form-target="submitText" class="flex items-center gap-2">
              <span class="material-symbols-outlined text-xl">lock</span>
              Pay &euro;<%= number_with_delimiter(@booking.total_price, delimiter: ",") %>
            </span>
            <span data-payment-form-target="submitSpinner" class="hidden flex items-center gap-2">
              <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              Processing payment...
            </span>
          </button>
        </div>
      </form>
    </div>

    <%# Back link %>
    <div class="text-center">
      <%= link_to booking_path(@booking), class: "inline-flex items-center gap-2 text-sm text-on-surface-variant hover:text-on-surface transition-colors" do %>
        <span class="material-symbols-outlined text-base">arrow_back</span>
        Back to Booking Details
      <% end %>
    </div>
  </div>
</section>
